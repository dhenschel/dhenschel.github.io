---
import { siteProfile } from "../data/site";
import LanguageSwitcher from "./LanguageSwitcher.astro";

const defaultProfileId = "dhenschel";
const startupProfiles = [
  {
    id: "guest-one",
    name: "Gast 01",
    nameKey: "startup.guestOne",
    image: "/profile-guest-monkey.webp",
    imageAlt: "Schwarz-weißes Affenportrait für Gastprofil 01",
    imageAltKey: "startup.monkeyAlt",
    available: false,
    status: "Noch nicht eingerichtet",
    statusKey: "startup.unavailable",
  },
  {
    id: defaultProfileId,
    name: siteProfile.name,
    nameKey: undefined,
    image: siteProfile.image,
    imageAlt: siteProfile.imageAlt,
    imageAltKey: "site.profileAlt",
    available: true,
    status: "Hauptprofil",
    statusKey: "startup.mainProfile",
  },
  {
    id: "guest-two",
    name: "Gast 02",
    nameKey: "startup.guestTwo",
    image: "/profile-guest-duck.webp",
    imageAlt: "Illustrierte Ente für Gastprofil 02",
    imageAltKey: "startup.duckAlt",
    available: false,
    status: "Noch nicht eingerichtet",
    statusKey: "startup.unavailable",
  },
];
const initialProfileIndex = startupProfiles.findIndex(
  (profile) => profile.id === defaultProfileId,
);
---

<script is:inline>
  (() => {
    let introSeen = false;
    try {
      introSeen = sessionStorage.getItem("dh-intro-seen") === "true";
    } catch {
      introSeen = true;
    }

    const knownHashes = new Set(["#menu", "#gallery", "#about", "#music"]);
    let initialHash = window.location.hash;
    if (!knownHashes.has(initialHash)) {
      initialHash = introSeen ? "#gallery" : "#menu";
      const baseUrl = `${window.location.pathname}${window.location.search}`;
      window.history.replaceState(
        { consoleView: initialHash.slice(1) },
        "",
        `${baseUrl}${initialHash}`,
      );
    }

    document.documentElement.dataset.boot =
      initialHash === "#menu" ? "ready" : "skip";
  })();
</script>

<noscript
  ><style>
    .startup-screen {
      display: none !important;
    }
  </style></noscript
>

<div
  class="startup-screen"
  data-startup-screen
  data-phase="ready"
  aria-hidden="true"
>
  <button
    class="startup-screen__skip"
    type="button"
    data-skip-startup
    data-i18n="startup.skip"
  >
    Überspringen
  </button>

  <div class="startup-screen__brand">DH</div>
  <div class="startup-screen__language">
    <LanguageSwitcher placement="menu" />
  </div>

  <div class="startup-screen__content">
    <p data-i18n="startup.selectProfile">Profil auswählen</p>
    <div
      class="startup-profile-carousel"
      role="region"
      aria-label="Profilauswahl"
      data-i18n-aria="startup.profileSelection"
      data-startup-carousel
    >
      <button
        class="startup-profile-carousel__arrow startup-profile-carousel__arrow--previous"
        type="button"
        aria-label="Vorheriges Profil auswählen"
        data-i18n-aria="startup.previous"
        data-profile-previous
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="m15 5-7 7 7 7"></path>
        </svg>
      </button>

      <div class="startup-profile-selector">
        {
          startupProfiles.map((profile, profileIndex) => {
            const isDefault = profile.id === defaultProfileId;
            const previousIndex =
              (initialProfileIndex - 1 + startupProfiles.length) %
              startupProfiles.length;
            const nextIndex =
              (initialProfileIndex + 1) % startupProfiles.length;
            const initialPosition = isDefault
              ? "active"
              : profileIndex === previousIndex
                ? "previous"
                : profileIndex === nextIndex
                  ? "next"
                  : "hidden";
            return (
              <article
                class:list={[
                  "startup-profile",
                  { "startup-profile--unavailable": !profile.available },
                ]}
                role="group"
                data-startup-profile
                data-profile-id={profile.id}
                data-profile-name={profile.name}
                data-profile-name-key={profile.nameKey}
                data-profile-available={String(profile.available)}
                data-profile-status={profile.status}
                data-profile-status-key={profile.statusKey}
                data-profile-default={isDefault ? "true" : undefined}
                data-carousel-position={initialPosition}
                aria-current={isDefault ? "true" : undefined}
                aria-label={`${profile.name}: ${profile.status}`}
              >
                <span class="profile-picture profile-picture--boot">
                  <img
                    src={profile.image}
                    alt={profile.imageAlt}
                    data-i18n-alt={profile.imageAltKey}
                    width="800"
                    height="800"
                  />
                </span>
                <strong data-i18n={profile.nameKey}>{profile.name}</strong>
                <small data-i18n={profile.statusKey}>{profile.status}</small>
              </article>
            );
          })
        }
      </div>

      <button
        class="startup-profile-carousel__arrow startup-profile-carousel__arrow--next"
        type="button"
        aria-label="Nächstes Profil auswählen"
        data-i18n-aria="startup.next"
        data-profile-next
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="m9 5 7 7-7 7"></path>
        </svg>
      </button>
    </div>

    <p
      class="startup-screen__profile-status"
      data-startup-profile-status
      aria-live="polite"
      data-i18n="startup.mainProfile"
    >
      Hauptprofil
    </p>

    <button class="startup-screen__start" type="button" data-start-console>
      <span>A</span>
      <i data-i18n="startup.start">Menü starten</i>
    </button>
  </div>

  <div class="startup-cursor" aria-hidden="true">
    <img src="/cursor-hand.svg" alt="" width="36" height="36" />
  </div>

  <p class="startup-screen__hint" data-i18n="startup.welcome">
    Willkommen zurück
  </p>
</div>

<script>
  import { t } from "../scripts/i18n";

  const startupScreen = document.querySelector<HTMLElement>(
    "[data-startup-screen]",
  );
  const startConsole = document.querySelector<HTMLButtonElement>(
    "[data-start-console]",
  );
  const startupProfiles = Array.from(
    document.querySelectorAll<HTMLElement>("[data-startup-profile]"),
  );
  const previousProfile = document.querySelector<HTMLButtonElement>(
    "[data-profile-previous]",
  );
  const nextProfile = document.querySelector<HTMLButtonElement>(
    "[data-profile-next]",
  );
  const startupProfileStatus = document.querySelector<HTMLElement>(
    "[data-startup-profile-status]",
  );
  const skipStartup = document.querySelector<HTMLButtonElement>(
    "[data-skip-startup]",
  );
  const replayStartupButtons = document.querySelectorAll<HTMLButtonElement>(
    "[data-replay-startup]",
  );
  const reducedMotionStartup = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;
  const defaultProfileIndex = Math.max(
    0,
    startupProfiles.findIndex(
      (profile) => profile.dataset.profileDefault === "true",
    ),
  );
  let selectedStartupProfileIndex = defaultProfileIndex;
  let startupProfilePicture =
    startupProfiles[defaultProfileIndex]?.querySelector<HTMLElement>(
      ".profile-picture--boot",
    ) ?? null;
  let startupTimers: number[] = [];
  type StartupDestination = "gallery" | "about" | "music";
  type StartupHistoryMode = "none" | "push" | "replace";
  let startupDestination: StartupDestination =
    window.location.hash === "#about"
      ? "about"
      : window.location.hash === "#music"
        ? "music"
        : "gallery";

  const setStartupRoute = (
    route: "menu" | StartupDestination,
    historyMode: StartupHistoryMode,
  ) => {
    if (historyMode === "none") return;
    const baseUrl = `${window.location.pathname}${window.location.search}`;
    const routeUrl = `${baseUrl}#${route}`;
    const state = { consoleView: route };
    if (historyMode === "push") {
      window.history.pushState(state, "", routeUrl);
    } else {
      window.history.replaceState(state, "", routeUrl);
    }
  };

  const clearStartupTimers = () => {
    startupTimers.forEach((timer) => window.clearTimeout(timer));
    startupTimers = [];
  };

  const selectStartupProfile = (index: number) => {
    if (!startupProfiles.length || !startConsole) return;

    const normalizedIndex =
      ((index % startupProfiles.length) + startupProfiles.length) %
      startupProfiles.length;
    const selectedProfile = startupProfiles[normalizedIndex];
    const selectedName = selectedProfile.dataset.profileNameKey
      ? t(selectedProfile.dataset.profileNameKey)
      : (selectedProfile.dataset.profileName ?? t("startup.profileFallback"));
    const selectedStatus = selectedProfile.dataset.profileStatusKey
      ? t(selectedProfile.dataset.profileStatusKey)
      : (selectedProfile.dataset.profileStatus ?? t("startup.selectProfile"));
    const profileAvailable =
      selectedProfile.dataset.profileAvailable === "true";

    selectedStartupProfileIndex = normalizedIndex;
    startupProfiles.forEach((profile, profileIndex) => {
      const previousIndex =
        (normalizedIndex - 1 + startupProfiles.length) % startupProfiles.length;
      const nextIndex = (normalizedIndex + 1) % startupProfiles.length;
      const position =
        profileIndex === normalizedIndex
          ? "active"
          : profileIndex === previousIndex
            ? "previous"
            : profileIndex === nextIndex
              ? "next"
              : "hidden";

      profile.dataset.carouselPosition = position;
      if (position === "active") {
        profile.setAttribute("aria-current", "true");
      } else {
        profile.removeAttribute("aria-current");
      }
      const profileName = profile.dataset.profileNameKey
        ? t(profile.dataset.profileNameKey)
        : (profile.dataset.profileName ?? t("startup.profileFallback"));
      const profileStatus = profile.dataset.profileStatusKey
        ? t(profile.dataset.profileStatusKey)
        : (profile.dataset.profileStatus ?? t("startup.selectProfile"));
      profile.setAttribute(
        "aria-label",
        t("startup.profileGroup", {
          name: profileName,
          status: profileStatus,
        }),
      );
    });

    startupProfilePicture = selectedProfile.querySelector<HTMLElement>(
      ".profile-picture--boot",
    );
    if (startupScreen) {
      startupScreen.dataset.activeProfile =
        selectedProfile.dataset.profileId ?? "unknown";
    }
    if (startupProfileStatus) {
      startupProfileStatus.textContent = selectedStatus;
    }

    startConsole.disabled = !profileAvailable;
    startConsole.setAttribute("aria-disabled", String(!profileAvailable));
    startConsole.setAttribute(
      "aria-label",
      profileAvailable
        ? t("startup.startWith", { name: selectedName })
        : t("startup.notReady"),
    );
    startConsole.title = profileAvailable
      ? t("startup.start")
      : t("startup.notReady");

    const previousIndex =
      (normalizedIndex - 1 + startupProfiles.length) % startupProfiles.length;
    const nextIndex = (normalizedIndex + 1) % startupProfiles.length;
    const previousProfileElement = startupProfiles[previousIndex];
    const nextProfileElement = startupProfiles[nextIndex];
    const previousName = previousProfileElement?.dataset.profileNameKey
      ? t(previousProfileElement.dataset.profileNameKey)
      : (previousProfileElement?.dataset.profileName ??
        t("startup.profileFallback"));
    const nextName = nextProfileElement?.dataset.profileNameKey
      ? t(nextProfileElement.dataset.profileNameKey)
      : (nextProfileElement?.dataset.profileName ??
        t("startup.profileFallback"));
    previousProfile?.setAttribute(
      "aria-label",
      t("startup.previousNamed", { name: previousName }),
    );
    nextProfile?.setAttribute(
      "aria-label",
      t("startup.nextNamed", { name: nextName }),
    );
  };

  const playTone = (frequency: number, duration: number, volume = 0.06) =>
    window.consoleAudio?.tone(frequency, duration, volume);

  const rotateStartupProfiles = (direction: -1 | 1) => {
    if (startupScreen?.dataset.phase !== "ready") return;
    selectStartupProfile(selectedStartupProfileIndex + direction);
    playTone(direction > 0 ? 560 : 470, 0.08, 0.035);
  };

  const setStartupCursorPath = (event: MouseEvent) => {
    if (!startupScreen) return;

    const buttonBounds = startConsole?.getBoundingClientRect();
    const profileBounds = startupProfilePicture?.getBoundingClientRect();
    const hasPointerPosition =
      event.detail > 0 && (event.clientX !== 0 || event.clientY !== 0);
    const startX = hasPointerPosition
      ? event.clientX
      : (buttonBounds?.left ?? window.innerWidth / 2) +
        (buttonBounds?.width ?? 0) / 2;
    const startY = hasPointerPosition
      ? event.clientY
      : (buttonBounds?.top ?? window.innerHeight / 2) +
        (buttonBounds?.height ?? 0) / 2;
    const targetX = profileBounds
      ? profileBounds.left + profileBounds.width / 2
      : window.innerWidth / 2;
    const targetY = profileBounds
      ? profileBounds.top + profileBounds.height / 2
      : window.innerHeight / 2 - 3.5 * 16;
    const cursorHotspotX = 14;
    const cursorHotspotY = 2;
    const originX = window.innerWidth / 2;
    const originY = window.innerHeight / 2;

    startupScreen.style.setProperty(
      "--startup-cursor-start-x",
      `${startX - originX - cursorHotspotX}px`,
    );
    startupScreen.style.setProperty(
      "--startup-cursor-start-y",
      `${startY - originY - cursorHotspotY}px`,
    );
    startupScreen.style.setProperty(
      "--startup-cursor-target-x",
      `${targetX - originX - cursorHotspotX}px`,
    );
    startupScreen.style.setProperty(
      "--startup-cursor-target-y",
      `${targetY - originY - cursorHotspotY}px`,
    );
  };

  const finishStartup = () => {
    clearStartupTimers();
    if (startupDestination === "gallery") {
      setStartupRoute("gallery", "replace");
    }
    window.dispatchEvent(
      new CustomEvent("console:view-request", {
        detail: { view: startupDestination, historyMode: "none" },
      }),
    );
    document.documentElement.dataset.boot = "done";
    startupScreen?.setAttribute("aria-hidden", "true");
    if (startupScreen) startupScreen.dataset.phase = "done";
    if (document.documentElement.dataset.cursorHidden === "true") {
      const cursorRestoreDelay = reducedMotionStartup ? 0 : 540;
      startupTimers.push(
        window.setTimeout(
          () => document.documentElement.removeAttribute("data-cursor-hidden"),
          cursorRestoreDelay,
        ),
      );
    }
    try {
      sessionStorage.setItem("dh-intro-seen", "true");
    } catch {
      // Session persistence is optional.
    }
  };

  const playStartup = (event: MouseEvent) => {
    if (startConsole?.disabled) return;
    clearStartupTimers();
    setStartupCursorPath(event);
    document.documentElement.dataset.cursorHidden = "true";
    document.documentElement.dataset.boot = "pending";
    startupScreen?.setAttribute("aria-hidden", "false");
    if (startupScreen) startupScreen.dataset.phase = "selecting";
    playTone(330, 0.12, 0.04);

    const hoverAt = reducedMotionStartup ? 80 : 780;
    const clickAt = reducedMotionStartup ? 180 : 1480;
    const finishAt = reducedMotionStartup ? 620 : 2850;

    startupTimers.push(
      window.setTimeout(() => playTone(540, 0.1, 0.05), hoverAt),
      window.setTimeout(() => {
        if (startupScreen) startupScreen.dataset.phase = "clicked";
        playTone(760, 0.16, 0.075);
        window.setTimeout(() => playTone(980, 0.2, 0.045), 90);
      }, clickAt),
      window.setTimeout(finishStartup, finishAt),
    );
  };

  const showStartupMenu = (historyMode: StartupHistoryMode = "push") => {
    clearStartupTimers();
    startupDestination = "gallery";
    if (window.location.hash !== "#menu") {
      setStartupRoute("menu", historyMode);
    }
    selectStartupProfile(defaultProfileIndex);
    document.documentElement.removeAttribute("data-cursor-hidden");
    document.documentElement.dataset.boot = "ready";
    startupScreen?.setAttribute("aria-hidden", "false");
    if (startupScreen) startupScreen.dataset.phase = "ready";
    window.setTimeout(() => startConsole?.focus({ preventScroll: true }), 30);
  };

  previousProfile?.addEventListener("click", () => rotateStartupProfiles(-1));
  nextProfile?.addEventListener("click", () => rotateStartupProfiles(1));
  startupScreen?.addEventListener("keydown", (event) => {
    if (event.key !== "ArrowLeft" && event.key !== "ArrowRight") return;
    event.preventDefault();
    rotateStartupProfiles(event.key === "ArrowLeft" ? -1 : 1);
  });

  selectStartupProfile(defaultProfileIndex);

  if (document.documentElement.dataset.boot === "ready") {
    startupScreen?.setAttribute("aria-hidden", "false");
  }

  startConsole?.addEventListener("click", playStartup);
  skipStartup?.addEventListener("click", finishStartup);
  replayStartupButtons.forEach((button) =>
    button.addEventListener("click", () => showStartupMenu("push")),
  );
  window.addEventListener("console:language-changed", () =>
    selectStartupProfile(selectedStartupProfileIndex),
  );
  window.addEventListener("popstate", () => {
    if (window.location.hash === "#menu") {
      showStartupMenu("none");
      return;
    }
    if (
      document.documentElement.dataset.boot === "ready" ||
      document.documentElement.dataset.boot === "pending"
    ) {
      clearStartupTimers();
      document.documentElement.dataset.boot = "done";
      startupScreen?.setAttribute("aria-hidden", "true");
      if (startupScreen) startupScreen.dataset.phase = "done";
      document.documentElement.removeAttribute("data-cursor-hidden");
    }
  });
</script>
