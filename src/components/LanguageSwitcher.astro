---
interface Props {
  placement?: "console" | "menu" | "site";
}

const { placement = "console" } = Astro.props;
---

<div
  class:list={["language-switcher", `language-switcher--${placement}`]}
  data-language-switcher
  data-open="false"
>
  <button
    class="language-switcher__toggle"
    type="button"
    data-language-toggle
    aria-haspopup="menu"
    aria-expanded="false"
    aria-label="Sprache auswählen"
  >
    <span class="language-switcher__flag" aria-hidden="true">
      <i class="language-switcher__flag-de"></i>
      <i class="language-switcher__flag-en"></i>
      <i class="language-switcher__flag-fr"></i>
      <i class="language-switcher__flag-es"></i>
    </span>
    <strong class="language-switcher__current" data-language-current>DE</strong>
  </button>

  <div
    class="language-switcher__menu"
    role="menu"
    aria-label="Sprache auswählen"
    data-i18n-aria="language.label"
  >
    <button type="button" role="menuitemradio" data-language-option="de">
      <span>DE</span><strong>Deutsch</strong><i aria-hidden="true">✓</i>
    </button>
    <button type="button" role="menuitemradio" data-language-option="en">
      <span>EN</span><strong>English</strong><i aria-hidden="true">✓</i>
    </button>
    <button type="button" role="menuitemradio" data-language-option="fr">
      <span>FR</span><strong>Français</strong><i aria-hidden="true">✓</i>
    </button>
    <button type="button" role="menuitemradio" data-language-option="es">
      <span>ES</span><strong>Español</strong><i aria-hidden="true">✓</i>
    </button>
  </div>
</div>
