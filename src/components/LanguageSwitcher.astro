---
interface Props {
  placement?: "console" | "menu" | "site";
}

const { placement = "console" } = Astro.props;
---

<div
  class:list={["language-switcher", `language-switcher--${placement}`]}
  data-language-switcher
  data-open="false"
>
  <button
    class="language-switcher__toggle"
    type="button"
    data-language-toggle
    aria-haspopup="menu"
    aria-expanded="false"
    aria-label="Sprache auswählen"
  >
    <span class="language-switcher__flag" aria-hidden="true">
      <img
        class="language-switcher__flag-image language-switcher__flag-de"
        src="/flags/de.svg"
        alt=""
      />
      <img
        class="language-switcher__flag-image language-switcher__flag-en"
        src="/flags/gb.svg"
        alt=""
      />
      <img
        class="language-switcher__flag-image language-switcher__flag-fr"
        src="/flags/fr.svg"
        alt=""
      />
      <img
        class="language-switcher__flag-image language-switcher__flag-es"
        src="/flags/es.svg"
        alt=""
      />
    </span>
    <strong class="language-switcher__current" data-language-current>DE</strong>
  </button>

  <div
    class="language-switcher__menu"
    role="menu"
    aria-label="Sprache auswählen"
    data-i18n-aria="language.label"
  >
    <button type="button" role="menuitemradio" data-language-option="de">
      <img
        class="language-switcher__option-flag"
        src="/flags/de.svg"
        alt=""
        aria-hidden="true"
      />
      <span class="language-switcher__option-code" aria-hidden="true">DE</span>
      <strong>Deutsch</strong><i aria-hidden="true">✓</i>
    </button>
    <button type="button" role="menuitemradio" data-language-option="en">
      <img
        class="language-switcher__option-flag"
        src="/flags/gb.svg"
        alt=""
        aria-hidden="true"
      />
      <span class="language-switcher__option-code" aria-hidden="true">EN</span>
      <strong>English</strong><i aria-hidden="true">✓</i>
    </button>
    <button type="button" role="menuitemradio" data-language-option="fr">
      <img
        class="language-switcher__option-flag"
        src="/flags/fr.svg"
        alt=""
        aria-hidden="true"
      />
      <span class="language-switcher__option-code" aria-hidden="true">FR</span>
      <strong>Français</strong><i aria-hidden="true">✓</i>
    </button>
    <button type="button" role="menuitemradio" data-language-option="es">
      <img
        class="language-switcher__option-flag"
        src="/flags/es.svg"
        alt=""
        aria-hidden="true"
      />
      <span class="language-switcher__option-code" aria-hidden="true">ES</span>
      <strong>Español</strong><i aria-hidden="true">✓</i>
    </button>
  </div>
</div>
