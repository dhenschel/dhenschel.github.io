---
import LanguageSwitcher from "./LanguageSwitcher.astro";

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<header class:list={["site-header", { "site-header--compact": compact }]}>
  <a
    class="brand"
    href="/"
    aria-label="D. Henschel – Startseite"
    data-i18n-aria="common.home"
  >
    <span class="brand__mark">DH</span>
    <span class="brand__signal" aria-hidden="true"></span>
  </a>

  <div class="site-header__nav-group">
    <LanguageSwitcher placement="site" />

    <nav
      class="site-nav"
      aria-label="Hauptnavigation"
      data-i18n-aria="site.navigation"
    >
      <a href="/#gallery" data-i18n="site.projects">Projekte</a>
      <a href="/#about" data-i18n="site.profile">Profil</a>
      <a href="/#gallery" data-i18n="site.contact">Kontakt</a>
    </nav>
  </div>

  <a
    class="header-link"
    href="https://github.com/dhenschel"
    target="_blank"
    rel="noreferrer"
  >
    GitHub
    <span aria-hidden="true">↗</span>
  </a>
</header>
