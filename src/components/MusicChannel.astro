---
import { musicTracks, shuffleDisc } from "../data/music";

const musicLibraryDiscs = [shuffleDisc, ...musicTracks];
---

<section
  class="console-view music-screen"
  data-console-view-panel="music"
  aria-labelledby="music-channel-title"
  aria-hidden="true"
  inert
>
  <div class="music-channel" data-music-channel>
    <header class="music-channel__header">
      <span data-i18n="music.channel">Music Channel</span>
      <h1 id="music-channel-title" tabindex="-1" data-music-heading>
        <span data-i18n="music.library">Sound Library</span>
      </h1>
    </header>

    <div
      class="music-carousel"
      aria-label="Hintergrundmusik auswählen"
      data-i18n-aria="music.choose"
      data-music-carousel
    >
      <button
        class="music-carousel__arrow music-carousel__arrow--previous"
        type="button"
        data-music-arrow="previous"
        aria-label="Vorherige Musik-Disc"
        data-i18n-aria="music.previous"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="m14.8 4.8-7.2 7.2 7.2 7.2 1.6-1.6-5.6-5.6 5.6-5.6-1.6-1.6Z"
          ></path>
        </svg>
      </button>

      <div class="music-carousel__stage">
        {
          musicLibraryDiscs.map((track, index) => (
            <button
              class="music-disc"
              type="button"
              data-music-disc
              data-track-id={track.id}
              data-shuffle-disc={track.id === "shuffle" ? "true" : undefined}
              data-carousel-position={index === 0 ? "active" : "visible"}
              data-carousel-distance={index}
              aria-label={`${track.title} auswählen und anhören`}
              data-i18n-aria="music.selectTrack"
              data-i18n-params={JSON.stringify({ title: track.title })}
              aria-pressed="false"
              tabindex={index === 0 ? "0" : "-1"}
              style={`--disc-color: ${track.color}; --disc-color-dark: ${track.colorDark}; --music-disc-index: ${index};`}
            >
              <span class="music-disc__surface" aria-hidden="true">
                <span class="music-disc__rings" />
                <span class="music-disc__label">
                  <small
                    data-i18n={
                      track.id === "shuffle"
                        ? "music.shuffle.label"
                        : `music.track.${track.translationKey}.label`
                    }
                  >
                    {track.label}
                  </small>
                  <strong>{track.shortTitle}</strong>
                  {track.id === "shuffle" && (
                    <span class="music-disc__question">?</span>
                  )}
                  <i />
                </span>
                <span class="music-disc__hole" />
              </span>
              {track.id !== "shuffle" && (
                <span class="music-disc__badges" aria-hidden="true">
                  <span data-music-default-badge="light" hidden>
                    ☀
                  </span>
                  <span data-music-default-badge="dark" hidden>
                    ☾
                  </span>
                </span>
              )}
              <span class="visually-hidden" data-music-disc-status />
            </button>
          ))
        }
      </div>

      <button
        class="music-carousel__arrow music-carousel__arrow--next"
        type="button"
        data-music-arrow="next"
        aria-label="Nächste Musik-Disc"
        data-i18n-aria="music.next"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="m9.2 4.8 7.2 7.2-7.2 7.2-1.6-1.6 5.6-5.6-5.6-5.6 1.6-1.6Z"
          ></path>
        </svg>
      </button>
    </div>

    <div class="music-channel__details" aria-live="polite">
      <p data-music-position>
        Disc 1 von {musicLibraryDiscs.length}
      </p>
      <h2 data-music-title>{shuffleDisc.title}</h2>
      <p data-music-description data-i18n="music.shuffle.description">
        {shuffleDisc.description}
      </p>
      <strong data-music-playing-status data-i18n="music.current"
        >Aktuelle Hintergrundmusik</strong
      >
    </div>

    <div class="music-channel__actions">
      <button class="music-channel__play" type="button" data-music-play>
        <span class="console-input-prompt" aria-hidden="true">
          <span class="console-keycaps console-input-prompt__keyboard">
            <kbd>↵</kbd>
            <b>/</b>
            <kbd>␣</kbd>
          </span>
          <span class="console-gamepad-key console-input-prompt__gamepad"
            >A</span
          >
        </span>
        <strong data-music-play-label data-i18n="music.listen">Anhören</strong>
      </button>
      <button type="button" data-music-default="light" aria-pressed="false">
        <span aria-hidden="true">☀</span>
        <strong data-i18n="music.dayDefault">Als Tag-Standard</strong>
      </button>
      <button type="button" data-music-default="dark" aria-pressed="false">
        <span aria-hidden="true">☾</span>
        <strong data-i18n="music.nightDefault">Als Nacht-Standard</strong>
      </button>
      <button
        type="button"
        data-shuffle-pool-open
        aria-haspopup="dialog"
        aria-expanded="false"
        hidden
      >
        <span class="music-shuffle-pool-icon" aria-hidden="true">
          <i></i><i></i><i></i>
        </span>
        <strong data-i18n="music.shuffle.pool">Pool</strong>
        <small data-shuffle-pool-count>4 CDs</small>
      </button>
    </div>

    <dialog
      class="music-shuffle-dialog"
      data-shuffle-dialog
      aria-labelledby="shuffle-pool-title"
    >
      <div class="music-shuffle-dialog__panel">
        <header>
          <div>
            <small data-i18n="music.shuffle.eyebrow">Zufallsauswahl</small>
            <h2 id="shuffle-pool-title" data-i18n="music.shuffle.poolTitle">
              Shuffle-Pool
            </h2>
          </div>
          <button
            type="button"
            data-shuffle-pool-close
            data-dialog-close
            aria-label="Shuffle-Pool schließen"
            data-i18n-aria="music.shuffle.poolClose"
          >
            ×
          </button>
        </header>
        <p data-i18n="music.shuffle.poolDescription">
          Wähle die CDs, die Shuffle verwenden darf.
        </p>
        <div class="music-shuffle-dialog__options">
          {
            musicTracks.map((track) => (
              <button
                type="button"
                data-shuffle-option={track.id}
                aria-pressed="true"
                style={`--pool-disc-color: ${track.color}; --pool-disc-color-dark: ${track.colorDark};`}
              >
                <span aria-hidden="true">
                  <i />
                </span>
                <strong>{track.title}</strong>
                <b aria-hidden="true">✓</b>
              </button>
            ))
          }
        </div>
        <footer>
          <span data-shuffle-pool-status aria-live="polite">4 CDs im Pool</span>
        </footer>
      </div>
    </dialog>
  </div>
</section>

<script>
  import {
    musicTrackIds,
    musicTracks,
    shuffleDisc,
    type ConsoleTheme,
    type MusicDiscId,
    type MusicTrackId,
  } from "../data/music";
  import { t } from "../scripts/i18n";

  const musicLibraryDiscs = [shuffleDisc, ...musicTracks];
  const shufflePoolStorageKey = "dh-console-shuffle-pool-v1";

  const musicDiscs = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-music-disc]"),
  );
  const musicCarousel = document.querySelector<HTMLElement>(
    "[data-music-carousel]",
  );
  const musicPrevious = document.querySelector<HTMLButtonElement>(
    '[data-music-arrow="previous"]',
  );
  const musicNext = document.querySelector<HTMLButtonElement>(
    '[data-music-arrow="next"]',
  );
  const musicPlay =
    document.querySelector<HTMLButtonElement>("[data-music-play]");
  const musicPlayLabel = document.querySelector<HTMLElement>(
    "[data-music-play-label]",
  );
  const musicPosition = document.querySelector<HTMLElement>(
    "[data-music-position]",
  );
  const musicTitle = document.querySelector<HTMLElement>("[data-music-title]");
  const musicDescription = document.querySelector<HTMLElement>(
    "[data-music-description]",
  );
  const musicPlayingStatus = document.querySelector<HTMLElement>(
    "[data-music-playing-status]",
  );
  const musicDefaultButtons = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-music-default]"),
  );
  const shufflePoolOpen = document.querySelector<HTMLButtonElement>(
    "[data-shuffle-pool-open]",
  );
  const shufflePoolCount = document.querySelector<HTMLElement>(
    "[data-shuffle-pool-count]",
  );
  const shuffleDialog = document.querySelector<HTMLDialogElement>(
    "[data-shuffle-dialog]",
  );
  const shufflePoolClose = document.querySelector<HTMLButtonElement>(
    "[data-shuffle-pool-close]",
  );
  const shufflePoolStatus = document.querySelector<HTMLElement>(
    "[data-shuffle-pool-status]",
  );
  const shuffleOptions = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-shuffle-option]"),
  );
  const headerMusicButton = document.querySelector<HTMLButtonElement>(
    "[data-music-channel-open]",
  );

  let selectedMusicIndex = 0;
  let musicState: ConsoleMusicState = {
    activeTrackId: "home-pulse",
    defaults: { light: "home-pulse", dark: "blue-hour" },
    enabled: true,
    playing: false,
  };
  let musicWheelDelta = 0;
  let musicWheelLockedUntil = 0;
  let musicWheelResetTimer: number | null = null;
  let musicDiscActivationLockedUntil = 0;
  let shuffleIsActive = false;
  let lastShuffleTrackId: MusicTrackId | null = null;

  const loadShufflePool = (): MusicTrackId[] => {
    try {
      const stored = JSON.parse(
        localStorage.getItem(shufflePoolStorageKey) ?? "null",
      );
      if (!Array.isArray(stored)) return [...musicTrackIds];
      const valid = musicTrackIds.filter((trackId) => stored.includes(trackId));
      return valid.length > 0 ? valid : [...musicTrackIds];
    } catch {
      return [...musicTrackIds];
    }
  };

  let shufflePool = loadShufflePool();

  const getSelectedDisc = () => musicLibraryDiscs[selectedMusicIndex];
  const getDiscDescription = (index = selectedMusicIndex) => {
    const disc = musicLibraryDiscs[index];
    return disc.id === "shuffle"
      ? t("music.shuffle.description")
      : t(`music.track.${disc.translationKey}.description`);
  };

  const getDiscRotation = (surface: HTMLElement) => {
    const currentTransform = getComputedStyle(surface).transform;
    if (currentTransform === "none") return 0;
    const matrix = new DOMMatrixReadOnly(currentTransform);
    const currentAngle = (Math.atan2(matrix.b, matrix.a) * 180) / Math.PI;
    return ((currentAngle % 360) + 360) % 360;
  };

  const getShufflePoolCountText = () =>
    t(
      shufflePool.length === 1
        ? "music.shuffle.poolCountOne"
        : "music.shuffle.poolCount",
      { count: shufflePool.length },
    );

  const updateShufflePoolUi = (announcement?: string) => {
    const countText = getShufflePoolCountText();
    if (shufflePoolCount) shufflePoolCount.textContent = countText;
    if (shufflePoolStatus) {
      shufflePoolStatus.textContent = announcement ?? countText;
    }
    shufflePoolOpen?.setAttribute(
      "aria-label",
      t("music.shuffle.poolOpenWithCount", { count: shufflePool.length }),
    );
    shuffleOptions.forEach((option) => {
      const trackId = option.dataset.shuffleOption as MusicTrackId;
      option.setAttribute(
        "aria-pressed",
        String(shufflePool.includes(trackId)),
      );
    });
  };

  const updateMusicState = () => {
    musicDiscs.forEach((disc) => {
      const discId = disc.dataset.trackId as MusicDiscId;
      const isShuffle = discId === "shuffle";
      const isActive = shuffleIsActive
        ? isShuffle
        : discId === musicState.activeTrackId;
      disc.dataset.activeTrack = String(isActive);
      disc.setAttribute("aria-pressed", String(isActive));
      if (!isActive) {
        const surface = disc.querySelector<HTMLElement>(".music-disc__surface");
        surface?.style.removeProperty("animation");
        surface?.style.removeProperty("--music-hover-angle");
        surface?.style.removeProperty("--music-resume-angle");
      }
      const status = disc.querySelector<HTMLElement>(
        "[data-music-disc-status]",
      );
      if (status) {
        status.textContent = isActive
          ? musicState.playing
            ? t("music.playing")
            : t("music.selected")
          : "";
      }
      const dayBadge = disc.querySelector<HTMLElement>(
        '[data-music-default-badge="light"]',
      );
      const nightBadge = disc.querySelector<HTMLElement>(
        '[data-music-default-badge="dark"]',
      );
      if (dayBadge) dayBadge.hidden = musicState.defaults.light !== discId;
      if (nightBadge) nightBadge.hidden = musicState.defaults.dark !== discId;
    });

    const selectedDisc = getSelectedDisc();
    const selectedIsShuffle = selectedDisc.id === "shuffle";
    const selectedIsActive = selectedIsShuffle
      ? shuffleIsActive
      : selectedDisc.id === musicState.activeTrackId;
    if (musicPlayLabel) {
      musicPlayLabel.textContent = selectedIsShuffle
        ? t(shuffleIsActive ? "music.shuffle.again" : "music.shuffle.play")
        : selectedIsActive && musicState.playing
          ? t("music.playing")
          : t("music.listen");
    }
    musicPlay?.setAttribute(
      "aria-label",
      selectedIsShuffle
        ? t("music.shuffle.playAria")
        : selectedIsActive && musicState.playing
          ? t("music.playingTrack", { title: selectedDisc.title })
          : t("music.listenTrack", { title: selectedDisc.title }),
    );
    if (musicPlayingStatus) {
      const activeTrack = musicTracks.find(
        (track) => track.id === musicState.activeTrackId,
      );
      musicPlayingStatus.textContent = selectedIsShuffle
        ? shuffleIsActive && activeTrack
          ? t("music.shuffle.playing", { title: activeTrack.title })
          : t("music.shuffle.hint")
        : selectedIsActive
          ? musicState.playing
            ? t("music.playing")
            : t("music.selectedBackground")
          : t(
              document.documentElement.dataset.inputMode === "gamepad"
                ? "music.playHintGamepad"
                : "music.playHint",
            );
    }

    musicDefaultButtons.forEach((button) => {
      const theme = button.dataset.musicDefault as ConsoleTheme;
      button.hidden = selectedIsShuffle;
      button.setAttribute(
        "aria-pressed",
        String(
          !selectedIsShuffle && musicState.defaults[theme] === selectedDisc.id,
        ),
      );
    });
    if (shufflePoolOpen) {
      shufflePoolOpen.hidden = !selectedIsShuffle;
      shufflePoolOpen.setAttribute(
        "aria-expanded",
        String(Boolean(shuffleDialog?.open)),
      );
    }

    if (headerMusicButton) {
      const activeTrack = musicTracks.find(
        (track) => track.id === musicState.activeTrackId,
      );
      headerMusicButton.title = activeTrack
        ? t("header.openMusicTrackTitle", { title: activeTrack.title })
        : t("header.openMusic");
      headerMusicButton.setAttribute(
        "aria-label",
        activeTrack
          ? t("header.openMusicTrack", { title: activeTrack.title })
          : t("header.openMusic"),
      );
    }
  };

  const updateMusicCarousel = (focusDisc = false) => {
    const total = musicDiscs.length;
    musicDiscs.forEach((disc, index) => {
      const offset = index - selectedMusicIndex;
      const distance = Math.abs(offset);
      const position = offset === 0 ? "active" : "visible";
      disc.dataset.carouselPosition = position;
      disc.dataset.carouselDistance = String(Math.min(distance, 5));
      disc.style.setProperty("--music-disc-index", String(offset));
      disc.style.setProperty(
        "--music-disc-direction",
        String(Math.sign(offset)),
      );
      if (position !== "active") {
        const surface = disc.querySelector<HTMLElement>(".music-disc__surface");
        surface?.style.removeProperty("animation");
        surface?.style.removeProperty("--music-hover-angle");
      }
      disc.tabIndex = position === "active" ? 0 : -1;
      disc.removeAttribute("aria-hidden");
    });

    if (musicPrevious) musicPrevious.disabled = selectedMusicIndex === 0;
    if (musicNext) musicNext.disabled = selectedMusicIndex === total - 1;

    const selectedDisc = getSelectedDisc();
    if (musicPosition) {
      musicPosition.textContent = t("music.position", {
        current: selectedMusicIndex + 1,
        total,
      });
    }
    if (musicTitle) {
      musicTitle.textContent =
        selectedDisc.id === "shuffle"
          ? t("music.shuffle.title")
          : selectedDisc.title;
    }
    if (musicDescription) musicDescription.textContent = getDiscDescription();
    updateMusicState();
    if (focusDisc)
      musicDiscs[selectedMusicIndex]?.focus({ preventScroll: true });
  };

  const closeShufflePool = (restoreFocus = false) => {
    if (!shuffleDialog?.open) return;
    shuffleDialog.close();
    if (shufflePoolOpen) shufflePoolOpen.disabled = false;
    shufflePoolOpen?.setAttribute("aria-expanded", "false");
    if (restoreFocus) shufflePoolOpen?.focus({ preventScroll: true });
  };

  const moveMusicSelection = (direction: number, focusDisc = true) => {
    const nextIndex = Math.max(
      0,
      Math.min(musicLibraryDiscs.length - 1, selectedMusicIndex + direction),
    );
    if (nextIndex === selectedMusicIndex) return false;
    if (musicLibraryDiscs[nextIndex]?.id !== "shuffle") shuffleIsActive = false;
    closeShufflePool();
    selectedMusicIndex = nextIndex;
    updateMusicCarousel(focusDisc);
    return true;
  };

  const playMusicNavigationSound = () => window.consoleAudio?.play("navigate");

  const selectActiveMusic = (focusDisc = false) => {
    const activeIndex = musicLibraryDiscs.findIndex(
      (disc) => disc.id === musicState.activeTrackId,
    );
    if (activeIndex >= 0) selectedMusicIndex = activeIndex;
    updateMusicCarousel(focusDisc);
  };

  const pickShuffleTrack = () => {
    let candidates = shufflePool.filter(
      (trackId) => trackId !== musicState.activeTrackId,
    );
    if (candidates.length === 0) candidates = [...shufflePool];
    if (candidates.length > 1 && lastShuffleTrackId) {
      const withoutLast = candidates.filter(
        (trackId) => trackId !== lastShuffleTrackId,
      );
      if (withoutLast.length > 0) candidates = withoutLast;
    }
    return candidates[Math.floor(Math.random() * candidates.length)];
  };

  const playSelectedMusic = (withKeyboardSound = false) => {
    const selectedDisc = getSelectedDisc();
    if (withKeyboardSound) window.consoleAudio?.play("confirm");
    if (selectedDisc.id === "shuffle") {
      const randomTrackId = pickShuffleTrack();
      if (!randomTrackId) return;
      shuffleIsActive = true;
      lastShuffleTrackId = randomTrackId;
      window.consoleAudio?.setTrack(randomTrackId);
      updateMusicState();
      return;
    }
    shuffleIsActive = false;
    window.consoleAudio?.setTrack(selectedDisc.id);
  };

  musicPrevious?.addEventListener("click", (event) => {
    event.stopPropagation();
    const moved = moveMusicSelection(-1);
    if (moved && event.detail > 0) playMusicNavigationSound();
  });
  musicNext?.addEventListener("click", (event) => {
    event.stopPropagation();
    const moved = moveMusicSelection(1);
    if (moved && event.detail > 0) playMusicNavigationSound();
  });
  musicPlay?.addEventListener("click", () => playSelectedMusic());

  shufflePoolOpen?.addEventListener("click", () => {
    if (!shuffleDialog) return;
    updateShufflePoolUi();
    shuffleDialog.showModal();
    shufflePoolOpen.disabled = true;
    shufflePoolOpen.setAttribute("aria-expanded", "true");
    window.requestAnimationFrame(() => {
      const selectedOption = shuffleOptions.find(
        (option) => option.getAttribute("aria-pressed") === "true",
      );
      selectedOption?.focus({ preventScroll: true });
    });
  });

  shufflePoolClose?.addEventListener("click", () => closeShufflePool(true));
  shuffleDialog?.addEventListener("cancel", (event) => {
    event.preventDefault();
    closeShufflePool(true);
  });
  shuffleDialog?.addEventListener("click", (event) => {
    if (event.target === shuffleDialog) closeShufflePool(true);
  });
  shuffleDialog?.addEventListener("close", () => {
    if (shufflePoolOpen) shufflePoolOpen.disabled = false;
    shufflePoolOpen?.setAttribute("aria-expanded", "false");
  });

  shuffleOptions.forEach((option) => {
    option.addEventListener("click", () => {
      const trackId = option.dataset.shuffleOption as MusicTrackId;
      const isIncluded = shufflePool.includes(trackId);
      if (isIncluded && shufflePool.length === 1) {
        updateShufflePoolUi(t("music.shuffle.poolMinimum"));
        window.consoleAudio?.play("boundary");
        return;
      }
      shufflePool = isIncluded
        ? shufflePool.filter((id) => id !== trackId)
        : musicTrackIds.filter(
            (id) => id === trackId || shufflePool.includes(id),
          );
      try {
        localStorage.setItem(
          shufflePoolStorageKey,
          JSON.stringify(shufflePool),
        );
      } catch {
        // The pool remains usable for the current session.
      }
      updateShufflePoolUi();
    });
  });

  musicCarousel?.addEventListener(
    "wheel",
    (event) => {
      if (document.documentElement.dataset.consoleView !== "music") return;
      const rawDelta =
        Math.abs(event.deltaY) >= Math.abs(event.deltaX)
          ? event.deltaY
          : event.deltaX;
      if (rawDelta === 0) return;

      event.preventDefault();
      const now = performance.now();
      if (now < musicWheelLockedUntil) return;

      const direction = Math.sign(rawDelta);
      if (musicWheelDelta !== 0 && Math.sign(musicWheelDelta) !== direction) {
        musicWheelDelta = 0;
      }
      const deltaMultiplier =
        event.deltaMode === 1 ? 16 : event.deltaMode === 2 ? 120 : 1;
      musicWheelDelta += rawDelta * deltaMultiplier;

      if (musicWheelResetTimer !== null) {
        window.clearTimeout(musicWheelResetTimer);
      }
      musicWheelResetTimer = window.setTimeout(() => {
        musicWheelDelta = 0;
        musicWheelResetTimer = null;
      }, 180);

      if (Math.abs(musicWheelDelta) < 36) return;
      const moved = moveMusicSelection(direction, false);
      musicWheelDelta = 0;
      if (!moved) return;
      musicWheelLockedUntil = now + 280;
      playMusicNavigationSound();
    },
    { passive: false },
  );

  musicDiscs.forEach((disc, index) => {
    const surface = disc.querySelector<HTMLElement>(".music-disc__surface");

    disc.addEventListener("pointerenter", () => {
      if (
        !surface ||
        disc.dataset.activeTrack !== "true" ||
        disc.dataset.carouselPosition !== "active"
      )
        return;
      const currentAngle = getDiscRotation(surface);
      surface.style.setProperty("--music-hover-angle", `${currentAngle}deg`);
      surface.style.animation =
        "music-disc-hover-align 840ms cubic-bezier(0.2, 0.72, 0.24, 1) forwards";
    });

    disc.addEventListener("pointerleave", () => {
      if (!surface) return;
      if (
        disc.dataset.activeTrack === "true" &&
        disc.dataset.carouselPosition === "active"
      ) {
        const currentAngle = getDiscRotation(surface);
        surface.style.setProperty("--music-resume-angle", `${currentAngle}deg`);
        surface.style.animation =
          "music-disc-playing-resume 14s linear infinite";
      } else {
        surface.style.removeProperty("animation");
        surface.style.removeProperty("--music-resume-angle");
      }
      surface.style.removeProperty("--music-hover-angle");
    });

    disc.addEventListener("click", (event) => {
      if (index !== selectedMusicIndex) {
        event.stopPropagation();
        if (musicLibraryDiscs[index]?.id !== "shuffle") {
          shuffleIsActive = false;
        }
        closeShufflePool();
        selectedMusicIndex = index;
        musicDiscActivationLockedUntil = performance.now() + 520;
        updateMusicCarousel(true);
        if (event.detail > 0) playMusicNavigationSound();
        return;
      }
      if (performance.now() < musicDiscActivationLockedUntil) return;
      playSelectedMusic();
    });
  });

  musicDefaultButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const theme = button.dataset.musicDefault as ConsoleTheme;
      const selectedDisc = getSelectedDisc();
      if (selectedDisc.id === "shuffle") return;
      window.consoleAudio?.setDefaultTrack(theme, selectedDisc.id);
    });
  });

  document.addEventListener("keydown", (event) => {
    if (document.documentElement.dataset.consoleView !== "music") return;
    if (shuffleDialog?.open) return;
    const eventTarget = event.target as HTMLElement | null;
    if (
      eventTarget?.matches('input, textarea, select, [contenteditable="true"]')
    ) {
      return;
    }
    if (event.key === "ArrowLeft" || event.key === "ArrowRight") {
      event.preventDefault();
      moveMusicSelection(event.key === "ArrowLeft" ? -1 : 1);
      return;
    }
    if (
      (event.key === "Enter" || event.key === " ") &&
      (eventTarget?.closest("[data-music-disc]") ||
        !eventTarget?.closest("button"))
    ) {
      event.preventDefault();
      playSelectedMusic(true);
    }
  });

  window.addEventListener("console:music-state", (event) => {
    const nextState = (event as CustomEvent<ConsoleMusicState>).detail;
    const activeTrackChanged =
      nextState.activeTrackId !== musicState.activeTrackId;
    musicState = nextState;
    if (
      activeTrackChanged &&
      document.documentElement.dataset.consoleView === "music" &&
      !(shuffleIsActive && getSelectedDisc().id === "shuffle")
    ) {
      selectActiveMusic();
    } else {
      updateMusicState();
    }
  });

  window.addEventListener("console:view-changed", (event) => {
    const view = (event as CustomEvent<{ view?: string }>).detail?.view;
    if (view === "music") {
      selectActiveMusic();
    } else {
      shuffleIsActive = false;
      closeShufflePool();
    }
  });

  window.addEventListener("console:language-changed", () => {
    updateShufflePoolUi();
    updateMusicCarousel();
  });
  window.addEventListener("console:input-mode-changed", updateMusicState);
  window.addEventListener("console:theme-changed", () => {
    shuffleIsActive = false;
  });

  const initialMusicState = window.consoleAudio?.getMusicState();
  if (initialMusicState) musicState = initialMusicState;
  updateShufflePoolUi();
  selectActiveMusic();
</script>
