---
import { projects } from "../data/projects";

const channelCount = 12;
const channels = Array.from({ length: channelCount }, (_, index) => ({
  index: String(index + 1).padStart(2, "0"),
  project: projects[index],
}));
---

<section class="channel-library" aria-labelledby="library-title">
  <h1 id="library-title" class="visually-hidden" data-i18n="gallery.title">
    Meine Websites
  </h1>

  <div
    class="channel-library__pages"
    aria-label="Menüseite 1 von 1"
    data-i18n-aria="gallery.page"
  >
    <span class="is-active"></span><span></span><span></span><span></span>
  </div>

  <ul
    class="channel-grid"
    aria-label="Website-Kanäle"
    data-i18n-aria="gallery.channels"
  >
    {
      channels.map(({ index, project }) => (
        <li class:list={["channel-item", { "channel-item--empty": !project }]}>
          {project ? (
            <a
              class="channel-card"
              href={project.view ? `#${project.view}` : (project.url ?? "#")}
              data-channel-link
              data-channel-title={project.title}
              data-channel-image={project.image}
              data-channel-view={project.view}
              aria-label={`${project.title} öffnen`}
              data-i18n-aria="gallery.open"
              data-i18n-params={JSON.stringify({ title: project.title })}
              style={`--channel-accent: ${project.accent}; --channel-accent-rgb: ${project.accentRgb};`}
            >
              <span class="channel-card__screen">
                {project.view === "about" ? (
                  <span class="about-channel-cover" aria-hidden="true">
                    <strong data-i18n="gallery.about">About Me</strong>
                  </span>
                ) : (
                  <>
                    <img
                      class="channel-card__cover"
                      src={project.image}
                      alt={`Vorschau von ${project.title}`}
                      data-i18n-alt="gallery.preview"
                      data-i18n-params={JSON.stringify({
                        title: project.title,
                      })}
                      width="1280"
                      height="720"
                      loading={Number(index) <= 5 ? "eager" : "lazy"}
                    />
                    {project.previewVideo && (
                      <video
                        class="channel-card__preview"
                        data-channel-preview
                        data-preview-src={project.previewVideo}
                        muted
                        playsinline
                        preload="none"
                        disablepictureinpicture
                        disableRemotePlayback
                        aria-hidden="true"
                      />
                    )}
                  </>
                )}
                <span class="channel-card__glass" aria-hidden="true" />
              </span>
            </a>
          ) : (
            <article
              class="channel-card channel-card--empty"
              aria-label={`Freier Kanal ${index}`}
              data-i18n-aria="gallery.empty"
              data-i18n-params={JSON.stringify({ index })}
            >
              <span class="channel-card__screen">
                <span class="empty-channel" aria-hidden="true">
                  <span>+</span>
                </span>
              </span>
            </article>
          )}
        </li>
      ))
    }
  </ul>
</section>

<div class="launch-transition" data-launch-transition aria-hidden="true" hidden>
  <img class="launch-transition__backdrop" data-launch-image src="" alt="" />
  <span class="launch-transition__veil"></span>
  <div class="launch-transition__loading" aria-hidden="true">
    <img
      class="launch-transition__cover"
      data-launch-loading-image
      src=""
      alt=""
      width="1280"
      height="720"
    />
    <strong data-launch-title></strong>
    <span class="launch-progress"><i></i></span>
    <p class="launch-fact">
      <span data-i18n="launch.fact">Völlig unnütze Info</span>
      <small data-launch-tip>Pixel werden alphabetisch sortiert.</small>
    </p>
  </div>
</div>

<script>
  import { getLaunchTips } from "../scripts/i18n";

  const channelLinks = document.querySelectorAll<HTMLAnchorElement>(
    "[data-channel-link]",
  );
  const launchOverlay = document.querySelector<HTMLElement>(
    "[data-launch-transition]",
  );
  const launchImage = launchOverlay?.querySelector<HTMLImageElement>(
    "[data-launch-image]",
  );
  const launchTitle = launchOverlay?.querySelector<HTMLElement>(
    "[data-launch-title]",
  );
  const launchLoadingImage = launchOverlay?.querySelector<HTMLImageElement>(
    "[data-launch-loading-image]",
  );
  const launchTip =
    launchOverlay?.querySelector<HTMLElement>("[data-launch-tip]");
  if (launchOverlay) {
    document.body.append(launchOverlay);
  }
  const reducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;
  const previewDelay = 1100;
  const previewDuration = 10000;
  const previewExitDuration = 820;
  const channelPreviewStops: Array<() => void> = [];

  channelLinks.forEach((link) => {
    const preview = link.querySelector<HTMLVideoElement>(
      "[data-channel-preview]",
    );
    const previewSource = preview?.dataset.previewSrc;
    if (!preview || !previewSource || reducedMotion) {
      return;
    }

    let armTimer: number | null = null;
    let playbackTimer: number | null = null;
    let resetTimer: number | null = null;
    let previewRun = 0;

    const clearPreviewTimers = () => {
      if (armTimer !== null) window.clearTimeout(armTimer);
      if (playbackTimer !== null) window.clearTimeout(playbackTimer);
      if (resetTimer !== null) window.clearTimeout(resetTimer);
      armTimer = null;
      playbackTimer = null;
      resetTimer = null;
    };

    const resetPreviewTime = () => {
      if (preview.readyState > 0) preview.currentTime = 0;
    };

    const isPreviewTargeted = () =>
      document.documentElement.dataset.inputMode === "gamepad"
        ? link.classList.contains("gamepad-pointer-target")
        : link.matches(":hover");

    const stopPreview = (cooldown = false, slowExit = false) => {
      const wasVisible = link.dataset.previewState === "playing";
      previewRun += 1;
      clearPreviewTimers();
      preview.pause();
      if (wasVisible && slowExit) {
        link.dataset.previewExit = "slow";
      } else {
        delete link.dataset.previewExit;
      }
      link.dataset.previewState = cooldown ? "cooldown" : "idle";
      if (wasVisible && slowExit) {
        resetTimer = window.setTimeout(() => {
          resetPreviewTime();
          delete link.dataset.previewExit;
        }, previewExitDuration);
      } else {
        resetPreviewTime();
      }
    };

    const startPreview = async () => {
      armTimer = null;
      if (
        link.dataset.previewState !== "arming" ||
        !isPreviewTargeted() ||
        document.documentElement.dataset.launching === "true"
      ) {
        stopPreview();
        return;
      }

      const currentRun = ++previewRun;
      link.dataset.previewState = "loading";
      if (!preview.src) {
        preview.src = previewSource;
        preview.load();
      }
      preview.muted = true;
      resetPreviewTime();

      try {
        await preview.play();
        if (
          currentRun !== previewRun ||
          !isPreviewTargeted() ||
          document.documentElement.dataset.launching === "true"
        ) {
          return;
        }
        link.dataset.previewState = "playing";
        playbackTimer = window.setTimeout(
          () => stopPreview(true, true),
          previewDuration,
        );
      } catch {
        if (currentRun === previewRun) stopPreview(true);
      }
    };

    const armPreview = () => {
      const state = link.dataset.previewState;
      if (
        document.documentElement.dataset.launching === "true" ||
        state === "arming" ||
        state === "loading" ||
        state === "playing" ||
        state === "cooldown"
      ) {
        return;
      }
      link.dataset.previewState = "arming";
      armTimer = window.setTimeout(startPreview, previewDelay);
    };

    link.addEventListener("pointerenter", armPreview);
    link.addEventListener("pointerleave", () => stopPreview());
    preview.addEventListener("ended", () => stopPreview(true, true));
    channelPreviewStops.push(() => stopPreview());
  });

  const stopAllChannelPreviews = () =>
    channelPreviewStops.forEach((stopPreview) => stopPreview());

  window.addEventListener("console:view-changed", stopAllChannelPreviews);

  document.addEventListener("visibilitychange", () => {
    if (document.visibilityState === "hidden") stopAllChannelPreviews();
  });
  window.addEventListener("pagehide", stopAllChannelPreviews);

  let activeSelectionAnimation: Animation | null = null;
  let activeSelectedLink: HTMLAnchorElement | null = null;
  let activeZoomAnimation: Animation | null = null;
  let activeLaunchController: AbortController | null = null;

  const waitForLaunch = (delay: number, signal: AbortSignal) =>
    new Promise<void>((resolve, reject) => {
      if (signal.aborted) {
        reject(new DOMException("Launch cancelled", "AbortError"));
        return;
      }

      const timer = window.setTimeout(resolve, delay);
      signal.addEventListener(
        "abort",
        () => {
          window.clearTimeout(timer);
          reject(new DOMException("Launch cancelled", "AbortError"));
        },
        { once: true },
      );
    });

  const cancelLaunchWork = () => {
    activeLaunchController?.abort();
    activeLaunchController = null;
    activeSelectionAnimation?.cancel();
    activeSelectionAnimation = null;
    activeZoomAnimation?.cancel();
    activeZoomAnimation = null;
    if (activeSelectedLink) {
      delete activeSelectedLink.dataset.launchSelected;
      activeSelectedLink = null;
    }
  };

  const playSelectionSound = () => {
    window.consoleAudio?.play("confirm");
  };

  const runSelectionAnimation = async (
    link: HTMLAnchorElement,
    screen: HTMLElement,
  ) => {
    activeSelectedLink = link;
    link.dataset.launchSelected = "true";

    if (reducedMotion || typeof screen.animate !== "function") {
      await new Promise<void>((resolve) =>
        requestAnimationFrame(() => resolve()),
      );
      return true;
    }

    const isHighlighted =
      link.matches(":hover") || link.matches(":focus-visible");
    const highlightedScale = window.matchMedia("(max-width: 700px)").matches
      ? 1.045
      : 1.075;
    const restingScale = isHighlighted ? highlightedScale : 1;
    const selectionAnimation = screen.animate(
      [
        { transform: `scale(${restingScale})`, offset: 0 },
        { transform: "scale(0.94)", offset: 0.34 },
        { transform: "scale(1.105)", offset: 0.72 },
        { transform: `scale(${restingScale})`, offset: 1 },
      ],
      {
        duration: 420,
        easing: "cubic-bezier(0.2, 0.82, 0.24, 1)",
      },
    );
    activeSelectionAnimation = selectionAnimation;

    try {
      await selectionAnimation.finished;
      if (selectionAnimation !== activeSelectionAnimation) return false;
      activeSelectionAnimation = null;
      return true;
    } catch {
      return false;
    }
  };

  const runLaunchSequence = async (
    destination: string,
    blackDelay: number,
    loadingDelay: number,
    closingDelay: number,
    navigationDelay: number,
  ) => {
    const controller = new AbortController();
    const { signal } = controller;
    activeLaunchController = controller;

    try {
      await waitForLaunch(blackDelay, signal);
      if (controller !== activeLaunchController || !launchOverlay) return;
      document.documentElement.dataset.cursorHidden = "true";
      launchOverlay.dataset.state = "black";

      await waitForLaunch(loadingDelay - blackDelay, signal);
      if (controller !== activeLaunchController || !launchOverlay) return;
      launchOverlay.dataset.state = "loading";

      await waitForLaunch(closingDelay - loadingDelay, signal);
      if (controller !== activeLaunchController || !launchOverlay) return;
      launchOverlay.dataset.state = "closing";

      await waitForLaunch(navigationDelay - closingDelay, signal);
      if (
        signal.aborted ||
        controller !== activeLaunchController ||
        document.visibilityState !== "visible"
      ) {
        return;
      }

      activeLaunchController = null;
      window.location.assign(destination);
    } catch (error) {
      if (!(error instanceof DOMException && error.name === "AbortError")) {
        console.error("Website launch failed", error);
      }
    }
  };

  const playLaunchSound = () => {
    window.consoleAudio?.play("launch");
  };

  channelLinks.forEach((link) => {
    link.addEventListener("click", (event) => {
      if (document.documentElement.dataset.launching === "true") {
        event.preventDefault();
        return;
      }

      const targetView = link.dataset.channelView;
      if (
        targetView &&
        !event.defaultPrevented &&
        event.button === 0 &&
        !event.metaKey &&
        !event.ctrlKey &&
        !event.shiftKey &&
        !event.altKey
      ) {
        event.preventDefault();
        if (document.documentElement.dataset.viewTransitioning === "true") {
          return;
        }

        const screen = link.querySelector<HTMLElement>(".channel-card__screen");
        if (!screen) {
          window.dispatchEvent(
            new CustomEvent("console:view-request", {
              detail: { view: targetView },
            }),
          );
          return;
        }

        stopAllChannelPreviews();
        cancelLaunchWork();
        document.documentElement.dataset.viewTransitioning = "true";
        playSelectionSound();

        void (async () => {
          try {
            const selectionCompleted = await runSelectionAnimation(
              link,
              screen,
            );
            if (!selectionCompleted || document.visibilityState !== "visible") {
              return;
            }
            window.dispatchEvent(
              new CustomEvent("console:view-request", {
                detail: { view: targetView },
              }),
            );
          } finally {
            delete document.documentElement.dataset.viewTransitioning;
          }
        })();
        return;
      }

      if (
        event.defaultPrevented ||
        event.button !== 0 ||
        event.metaKey ||
        event.ctrlKey ||
        event.shiftKey ||
        event.altKey ||
        !launchOverlay
      ) {
        return;
      }

      event.preventDefault();
      const screen = link.querySelector<HTMLElement>(".channel-card__screen");
      if (!screen) {
        window.location.assign(link.href);
        return;
      }

      const destination = link.href;
      const image = link.dataset.channelImage ?? "";
      const title = link.dataset.channelTitle ?? "Website";

      stopAllChannelPreviews();
      cancelLaunchWork();
      document.documentElement.dataset.launching = "true";
      window.dispatchEvent(new CustomEvent("console:launch-start"));
      playSelectionSound();

      void (async () => {
        const selectionCompleted = await runSelectionAnimation(link, screen);
        if (
          !selectionCompleted ||
          document.documentElement.dataset.launching !== "true" ||
          document.visibilityState !== "visible"
        ) {
          return;
        }

        const bounds = screen.getBoundingClientRect();
        const startRadius = getComputedStyle(screen).borderRadius;

        launchOverlay.style.setProperty("--launch-left", `${bounds.left}px`);
        launchOverlay.style.setProperty("--launch-top", `${bounds.top}px`);
        launchOverlay.style.setProperty("--launch-width", `${bounds.width}px`);
        launchOverlay.style.setProperty(
          "--launch-height",
          `${bounds.height}px`,
        );
        if (launchImage) launchImage.src = image;
        if (launchLoadingImage) launchLoadingImage.src = image;
        if (launchTitle) launchTitle.textContent = title;
        if (launchTip) {
          const launchTips = getLaunchTips();
          launchTip.textContent =
            launchTips[Math.floor(Math.random() * launchTips.length)];
        }
        launchOverlay.hidden = false;
        launchOverlay.dataset.state = "ready";
        playLaunchSound();

        void launchOverlay.offsetWidth;

        requestAnimationFrame(() => {
          launchOverlay.dataset.state = "zoom";
          activeZoomAnimation = launchOverlay.animate(
            [
              {
                top: `${bounds.top}px`,
                left: `${bounds.left}px`,
                width: `${bounds.width}px`,
                height: `${bounds.height}px`,
                borderRadius: startRadius,
              },
              {
                top: "0px",
                left: "0px",
                width: `${window.innerWidth}px`,
                height: `${window.innerHeight}px`,
                borderRadius: "0px",
              },
            ],
            {
              duration: reducedMotion ? 240 : 720,
              easing: "cubic-bezier(0.16, 0.82, 0.2, 1)",
              fill: "forwards",
            },
          );
        });

        const blackDelay = reducedMotion ? 300 : 780;
        const loadingDelay = reducedMotion ? 1300 : 2200;
        const closingDelay = reducedMotion ? 2200 : 5600;
        const navigationDelay = reducedMotion ? 2800 : 6500;

        void runLaunchSequence(
          destination,
          blackDelay,
          loadingDelay,
          closingDelay,
          navigationDelay,
        );
      })();
    });
  });

  const suspendLaunchTransition = () => {
    cancelLaunchWork();
  };

  const resetLaunchTransition = () => {
    suspendLaunchTransition();
    document.documentElement.removeAttribute("data-launching");
    document.documentElement.removeAttribute("data-cursor-hidden");
    if (!launchOverlay) return;
    launchOverlay.hidden = true;
    delete launchOverlay.dataset.state;
    launchOverlay.style.removeProperty("--launch-left");
    launchOverlay.style.removeProperty("--launch-top");
    launchOverlay.style.removeProperty("--launch-width");
    launchOverlay.style.removeProperty("--launch-height");
  };

  window.addEventListener("pageshow", (event) => {
    resetLaunchTransition();
    if (event.persisted) {
      window.setTimeout(() => window.location.reload(), 0);
    }
  });
  window.addEventListener("pagehide", suspendLaunchTransition);
  window.addEventListener("popstate", resetLaunchTransition);
  document.addEventListener("visibilitychange", () => {
    if (document.visibilityState === "hidden") {
      suspendLaunchTransition();
    } else if (document.documentElement.dataset.launching === "true") {
      resetLaunchTransition();
    }
  });
</script>
