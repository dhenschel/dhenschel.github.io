---
import { projects } from "../data/projects";

const onlineProjects = projects.filter((project) => project.url).length;
---

<section class="channel-library" aria-labelledby="library-title">
  <header class="channel-library__header">
    <div>
      <p><span aria-hidden="true"></span> Website Library</p>
      <h1 id="library-title">Meine Kanäle</h1>
    </div>
    <div class="channel-library__page" aria-label="Galerieseite 1 von 1">
      <span>01</span>
      <i></i>
      <span>01</span>
    </div>
  </header>

  <ul class="channel-grid" aria-label="Websites">
    {
      projects.map((project) => (
        <li
          class:list={[
            "channel-item",
            { "channel-item--empty": project.placeholder },
          ]}
          style={`--channel-accent: ${project.accent}; --channel-accent-rgb: ${project.accentRgb};`}
        >
          {project.url ? (
            <a
              class="channel-card"
              href={project.url}
              target="_blank"
              rel="noreferrer"
              aria-label={`${project.title} öffnen`}
            >
              <span class="channel-card__screen">
                <img
                  src={project.image}
                  alt={`Vorschau von ${project.title}`}
                  width="1280"
                  height="720"
                  loading={project.index === "01" ? "eager" : "lazy"}
                />
                <span class="channel-card__shade" aria-hidden="true" />
                <span class="channel-card__number">{project.index}</span>
                <span class="channel-card__status">
                  <i aria-hidden="true" /> {project.status}
                </span>
                <span class="channel-card__launch" aria-hidden="true">
                  ↗
                </span>
              </span>
              <span class="channel-card__info">
                <span>
                  <small>{project.category}</small>
                  <strong>{project.title}</strong>
                </span>
                <span class="channel-card__year">{project.year}</span>
              </span>
            </a>
          ) : (
            <article
              class="channel-card channel-card--empty"
              aria-label={`${project.title}, noch nicht belegt`}
            >
              <span class="channel-card__screen">
                <span class="empty-channel" aria-hidden="true">
                  <span>＋</span>
                  <small>Freier Kanal</small>
                </span>
                <span class="channel-card__number">{project.index}</span>
              </span>
              <span class="channel-card__info">
                <span>
                  <small>{project.category}</small>
                  <strong>{project.title}</strong>
                </span>
                <span class="channel-card__year">SOON</span>
              </span>
            </article>
          )}
        </li>
      ))
    }
  </ul>

  <footer class="channel-dock">
    <div class="channel-dock__hint" aria-hidden="true">
      <span>A</span>
      <p>
        <strong>Kanal öffnen</strong><small
          >Website wird in einem neuen Tab gestartet</small
        >
      </p>
    </div>
    <div class="channel-dock__pages" aria-hidden="true">
      <i class="is-active"></i><i></i><i></i>
    </div>
    <p class="channel-dock__online">
      <i aria-hidden="true"></i>{onlineProjects.toString().padStart(2, "0")} Kanäle
      online
    </p>
  </footer>
</section>
