---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectHub from "../components/ProjectHub.astro";
import SiteFooter from "../components/SiteFooter.astro";
import StartupScreen from "../components/StartupScreen.astro";
import { projects } from "../data/projects";
import { siteProfile } from "../data/site";
import "../styles/console.css";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://www.dhenschel.de/#person",
      name: siteProfile.name,
      url: "https://www.dhenschel.de",
      sameAs: [siteProfile.github],
      jobTitle: siteProfile.role,
    },
    {
      "@type": "CollectionPage",
      name: "D. Henschel — Website Console",
      url: "https://www.dhenschel.de/",
      about: { "@id": "https://www.dhenschel.de/#person" },
      mainEntity: {
        "@type": "ItemList",
        itemListElement: projects
          .filter((project) => project.url)
          .map((project, index) => ({
            "@type": "ListItem",
            position: index + 1,
            item: {
              "@type": "WebSite",
              name: project.title,
              url: project.url,
              creator: { "@id": "https://www.dhenschel.de/#person" },
            },
          })),
      },
    },
  ],
};
---

<BaseLayout
  title="D. Henschel — Home Console"
  description="Das persönliche Home-Menü von D. Henschel mit ClipCollection, CozySite, Restaurant Lava und kommenden Websites."
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(structuredData)}
  />

  <StartupScreen />

  <header class="console-topbar">
    <a class="console-topbar__home" href="/" aria-label="Home-Menü">
      <span class="console-topbar__home-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" role="img">
          <path d="m4 10 8-6 8 6v9a1 1 0 0 1-1 1h-5v-6h-4v6H5a1 1 0 0 1-1-1v-9Z"
          ></path>
        </svg>
      </span>
      <span><small>System</small><strong>Home</strong></span>
    </a>

    <div class="console-topbar__section">
      <span class="console-topbar__online"><i></i> Online</span>
      <span class="console-topbar__library">Website Library</span>
    </div>

    <nav class="console-actions" aria-label="Systemaktionen">
      <a
        class="console-action"
        href={siteProfile.github}
        target="_blank"
        rel="noreferrer"
        aria-label="GitHub-Profil öffnen"
      >
        <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
          <path
            d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.88c-2.78.6-3.37-1.18-3.37-1.18-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.9 1.53 2.35 1.09 2.92.83.09-.65.35-1.09.64-1.34-2.22-.25-4.56-1.11-4.56-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.6 9.6 0 0 1 12 6.82a9.6 9.6 0 0 1 2.5.34c1.91-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.86V21c0 .27.18.58.69.48A10 10 0 0 0 12 2Z"
          ></path>
        </svg>
        <span>GitHub</span>
      </a>
      <button
        class="console-action"
        type="button"
        data-replay-startup
        aria-label="Startup erneut abspielen"
      >
        <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
          <path
            d="M12 3a9 9 0 1 0 8.55 6.2l-1.9.63A7 7 0 1 1 17 7.15L14.2 10H21V3.2l-2.58 2.57A8.96 8.96 0 0 0 12 3Z"
          ></path>
        </svg>
        <span>Startup</span>
      </button>
    </nav>

    <div class="console-clock">
      <time data-console-time>--:--</time>
      <span data-console-date>--.--.----</span>
    </div>

    <div class="console-user">
      <span><small>Player 01</small><strong>{siteProfile.name}</strong></span>
      <div class="profile-picture profile-picture--bar">
        <img
          src={siteProfile.image}
          alt={siteProfile.imageAlt}
          width="800"
          height="800"
        />
      </div>
    </div>
  </header>

  <main id="main-content" class="console-home">
    <div class="console-background" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>
    <section class="home-screen" aria-label="Website-Konsole">
      <div class="home-screen__welcome">
        <div>
          <p>Player 01</p>
          <strong>Willkommen zurück, D.</strong>
        </div>
        <p>Wähle einen Kanal, um eine Website zu starten.</p>
      </div>
      <ProjectHub />
    </section>
  </main>

  <SiteFooter />

  <script>
    const timeElements = document.querySelectorAll<HTMLElement>(
      "[data-console-time]",
    );
    const dateElements = document.querySelectorAll<HTMLElement>(
      "[data-console-date]",
    );

    const updateConsoleTime = () => {
      const now = new Date();
      const time = new Intl.DateTimeFormat("de-DE", {
        timeZone: "Europe/Berlin",
        hour: "2-digit",
        minute: "2-digit",
        hour12: false,
      }).format(now);
      const date = new Intl.DateTimeFormat("de-DE", {
        timeZone: "Europe/Berlin",
        day: "2-digit",
        month: "2-digit",
        year: "numeric",
      }).format(now);

      timeElements.forEach((element) => (element.textContent = time));
      dateElements.forEach((element) => (element.textContent = date));
    };

    updateConsoleTime();
    window.setInterval(updateConsoleTime, 60_000);
  </script>
</BaseLayout>
