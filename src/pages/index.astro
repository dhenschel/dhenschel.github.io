---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactDialog from "../components/ContactDialog.astro";
import InputModeIndicator from "../components/InputModeIndicator.astro";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import MusicChannel from "../components/MusicChannel.astro";
import ProjectHub from "../components/ProjectHub.astro";
import StartupScreen from "../components/StartupScreen.astro";
import { projects } from "../data/projects";
import { siteProfile } from "../data/site";
import "../styles/console.css";

const websiteProjects = projects.filter((project) => project.url);

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://www.dhenschel.de/#person",
      name: "D. Henschel",
      url: "https://www.dhenschel.de",
      sameAs: [siteProfile.github],
      jobTitle: siteProfile.role,
    },
    {
      "@type": "CollectionPage",
      name: "D. Henschel — Website-Menü",
      url: "https://www.dhenschel.de/",
      about: { "@id": "https://www.dhenschel.de/#person" },
      mainEntity: {
        "@type": "ItemList",
        itemListElement: websiteProjects.map((project, index) => ({
          "@type": "ListItem",
          position: index + 1,
          item: {
            "@type": "WebSite",
            name: project.title,
            url: project.url,
            creator: { "@id": "https://www.dhenschel.de/#person" },
          },
        })),
      },
    },
  ],
};
---

<BaseLayout
  title="D. Henschel — Website-Menü"
  description="Das persönliche Website-Menü von D. Henschel mit ClipCollection, CozySite, Restaurant Lava, BootBucht24 und kommenden Projekten."
  titleKey="page.home.title"
  descriptionKey="page.home.description"
>
  <script is:inline>
    (() => {
      const storageKey = "dh-console-theme";
      let storedTheme = null;
      try {
        storedTheme = localStorage.getItem(storageKey);
      } catch {
        storedTheme = null;
      }
      const systemTheme = window.matchMedia("(prefers-color-scheme: dark)")
        .matches
        ? "dark"
        : "light";
      document.documentElement.dataset.consoleTheme =
        storedTheme === "dark" || storedTheme === "light"
          ? storedTheme
          : systemTheme;
      document.documentElement.dataset.consoleView =
        window.location.hash === "#about"
          ? "about"
          : window.location.hash === "#music"
            ? "music"
            : "gallery";
    })();
  </script>

  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(structuredData)}
  />

  <StartupScreen />

  <header class="console-topbar">
    <div class="console-identity">
      <button
        class="console-back-button"
        type="button"
        data-console-back
        aria-label="Zur Website-Galerie zurückkehren"
        data-i18n-aria="header.backGallery"
        aria-hidden="true"
        tabindex="-1"
        title="Zurück zur Galerie"
        data-i18n-title="header.backGalleryShort"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="m14.8 4.8-7.2 7.2 7.2 7.2 1.6-1.6-5.6-5.6 5.6-5.6-1.6-1.6Z"
          ></path>
        </svg>
      </button>

      <button
        class="console-profile-button"
        type="button"
        data-replay-startup
        aria-label="Profilmenü von dhenschel öffnen"
        data-i18n-aria="header.openProfile"
      >
        <span class="profile-picture profile-picture--bar">
          <img
            src={siteProfile.image}
            alt={siteProfile.imageAlt}
            data-i18n-alt="site.profileAlt"
            width="800"
            height="800"
          />
        </span>
        <strong>{siteProfile.name}</strong>
      </button>

      <LanguageSwitcher placement="console" />

      <button
        class="header-music-button"
        type="button"
        data-music-channel-open
        aria-label="Music Channel öffnen"
        data-i18n-aria="header.openMusic"
        aria-pressed="false"
        title="Music Channel öffnen"
        data-i18n-title="header.openMusic"
      >
        <span class="header-music-button__motion" aria-hidden="true">
          <span class="header-music-button__disc">
            <i></i>
          </span>
        </span>
      </button>
    </div>

    <InputModeIndicator placement="header" />

    <div class="console-status">
      <div class="console-clock">
        <span data-console-date>--.--.----</span>
        <time data-console-time>--:--</time>
      </div>
      <span class="console-online"
        ><i></i> <b data-i18n="common.online">Online</b></span
      >
    </div>
  </header>

  <main id="main-content" class="console-home">
    <div class="console-background" data-console-background aria-hidden="true">
      <span></span><span></span><span></span><span></span>
    </div>
    <script>
      const consoleBackground = document.querySelector<HTMLElement>(
        "[data-console-background]",
      );

      const randomBetween = (minimum: number, maximum: number) =>
        minimum + Math.random() * (maximum - minimum);
      const randomInteger = (minimum: number, maximum: number) =>
        Math.floor(randomBetween(minimum, maximum + 1));
      const randomSigned = (minimum: number, maximum: number) =>
        randomBetween(minimum, maximum) * (Math.random() < 0.5 ? -1 : 1);
      const decimal = (value: number) => value.toFixed(2);

      if (consoleBackground) {
        const particleCount = randomInteger(3, 7);
        const particles = Array.from(
          consoleBackground.querySelectorAll<HTMLElement>("span"),
        );

        while (particles.length < particleCount) {
          const particle = document.createElement("span");
          consoleBackground.append(particle);
          particles.push(particle);
        }

        particles.forEach((particle, index) => {
          if (index >= particleCount) {
            particle.remove();
            return;
          }

          const size = randomBetween(0.38, 1.15);
          const duration = randomBetween(7, 12);
          particle.style.top = `${decimal(randomBetween(12, 84))}%`;
          particle.style.left = `${decimal(randomBetween(4, 92))}%`;
          particle.style.right = "auto";
          particle.style.bottom = "auto";
          particle.style.width = `${decimal(size)}rem`;
          particle.style.height = `${decimal(size)}rem`;
          particle.style.setProperty(
            "--particle-x",
            `${decimal(randomSigned(4, 9))}rem`,
          );
          particle.style.setProperty(
            "--particle-y",
            `${decimal(randomSigned(3.5, 8))}rem`,
          );
          particle.style.setProperty(
            "--particle-scale",
            decimal(randomBetween(0.76, 1.52)),
          );
          particle.style.setProperty(
            "--particle-duration",
            `${decimal(duration)}s`,
          );
          particle.style.setProperty(
            "--particle-pulse",
            `${decimal(randomBetween(2.6, 4.2))}s`,
          );
          particle.style.setProperty(
            "--particle-delay",
            `-${decimal(randomBetween(0, duration))}s`,
          );
          particle.style.animationDirection =
            Math.random() < 0.5 ? "alternate" : "alternate-reverse";
        });

        consoleBackground.style.setProperty(
          "--orbit-lower-bottom",
          `${decimal(randomBetween(-34, -28))}rem`,
        );
        consoleBackground.style.setProperty(
          "--orbit-lower-height",
          `${decimal(randomBetween(38, 48))}rem`,
        );
        consoleBackground.style.setProperty(
          "--orbit-lower-duration",
          `${decimal(randomBetween(12, 18))}s`,
        );
        consoleBackground.style.setProperty(
          "--orbit-lower-delay",
          `-${decimal(randomBetween(0, 15))}s`,
        );
        consoleBackground.style.setProperty(
          "--orbit-lower-direction",
          Math.random() < 0.5 ? "alternate" : "alternate-reverse",
        );
        consoleBackground.style.setProperty(
          "--orbit-upper-top",
          `${decimal(randomBetween(7, 16))}rem`,
        );
        consoleBackground.style.setProperty(
          "--orbit-upper-height",
          `${decimal(randomBetween(25, 36))}rem`,
        );
        consoleBackground.style.setProperty(
          "--orbit-upper-duration",
          `${decimal(randomBetween(10, 16))}s`,
        );
        consoleBackground.style.setProperty(
          "--orbit-upper-delay",
          `-${decimal(randomBetween(0, 13))}s`,
        );
        consoleBackground.style.setProperty(
          "--orbit-upper-direction",
          Math.random() < 0.5 ? "alternate" : "alternate-reverse",
        );
      }
    </script>
    <div class="home-screen console-view-stage">
      <div
        class="console-view console-view--gallery"
        data-console-view-panel="gallery"
      >
        <ProjectHub />
      </div>

      <section
        class="console-view about-screen"
        data-console-view-panel="about"
        aria-labelledby="about-title"
        aria-hidden="true"
        inert
      >
        <div class="about-panel">
          <header class="about-panel__header">
            <span data-i18n="about.channel">Profilkanal</span>
            <h1
              id="about-title"
              tabindex="-1"
              data-about-heading
              data-i18n="about.title"
            >
              About Me
            </h1>
          </header>
          <div
            class="about-panel__content"
            data-about-content
            aria-label="Persönliche Informationen"
            data-i18n-aria="about.information"
          >
          </div>
        </div>
      </section>

      <MusicChannel />
    </div>
  </main>

  <footer class="console-bottombar">
    <button
      class="contact-button"
      type="button"
      data-contact-open
      aria-label="Kontaktformular öffnen"
      data-i18n-aria="controls.openContact"
      title="Kontakt"
      data-i18n-title="common.contact"
    >
      <span>
        <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
          <path
            d="M3 5h18v14H3V5Zm2 2v.3l7 5.25 7-5.25V7H5Zm14 10V9.8l-7 5.25L5 9.8V17h14Z"
          ></path>
        </svg>
      </span>
    </button>

    <nav aria-label="Rechtliches" data-i18n-aria="common.legal">
      <a href="/impressum/" data-i18n="common.imprint">Impressum</a>
      <a href="/datenschutz/" data-i18n="common.privacy">Datenschutz</a>
    </nav>

    <div class="console-bottombar__actions">
      <button
        class="theme-toggle sound-toggle"
        type="button"
        data-sound-toggle
        aria-label="Sound ausschalten"
        aria-pressed="true"
        title="Sound ausschalten"
      >
        <svg class="sound-toggle__on" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M4 9v6h4l5 4V5L8 9H4Zm11.7-1.7a1 1 0 0 1 1.4 0 6.6 6.6 0 0 1 0 9.4 1 1 0 1 1-1.4-1.4 4.6 4.6 0 0 0 0-6.6 1 1 0 0 1 0-1.4Zm2.8-2.8a1 1 0 0 1 1.4 0 10.6 10.6 0 0 1 0 15 1 1 0 1 1-1.4-1.4 8.6 8.6 0 0 0 0-12.2 1 1 0 0 1 0-1.4Z"
          ></path>
        </svg>
        <svg class="sound-toggle__off" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M4 9v6h4l5 4V5L8 9H4Zm11.3.3 1.4-1.4 2.1 2.1 2.1-2.1 1.4 1.4-2.1 2.1 2.1 2.1-1.4 1.4-2.1-2.1-2.1 2.1-1.4-1.4 2.1-2.1-2.1-2.1Z"
          ></path>
        </svg>
        <strong data-sound-label>Sound an</strong>
      </button>
      <button
        class="theme-toggle"
        type="button"
        data-theme-toggle
        aria-label="Farbschema wechseln"
        data-i18n-aria="controls.changeTheme"
      >
        <svg class="theme-toggle__sun" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0-5 1 1.8L12 5l-1-1.2L12 2Zm0 20-1-1.8 1-1.2 1 1.2L12 22ZM2 12l1.8-1L5 12l-1.2 1L2 12Zm20 0-1.8 1L19 12l1.2-1L22 12ZM4.9 4.9l2 .55.2 1.65-1.65-.2-.55-2Zm14.2 14.2-2-.55-.2-1.65 1.65.2.55 2Zm0-14.2-.55 2-1.65.2.2-1.65 2-.55ZM4.9 19.1l.55-2 1.65-.2-.2 1.65-2 .55Z"
          ></path>
        </svg>
        <svg class="theme-toggle__moon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.5 15.2A8.5 8.5 0 0 1 8.8 3.5 9 9 0 1 0 20.5 15.2Z"
          ></path>
        </svg>
        <strong data-theme-label>Theme</strong>
      </button>
      <button
        class="theme-toggle fullscreen-toggle"
        type="button"
        data-fullscreen-toggle
        aria-label="Vollbildmodus starten"
        aria-pressed="false"
        title="Vollbildmodus starten"
      >
        <svg
          class="fullscreen-toggle__enter"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            d="M4 4h6v2H6v4H4V4Zm10 0h6v6h-2V6h-4V4ZM4 14h2v4h4v2H4v-6Zm14 0h2v6h-6v-2h4v-4Z"
          ></path>
        </svg>
        <svg
          class="fullscreen-toggle__exit"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            d="M8 4h2v6H4V8h4V4Zm6 0h2v4h4v2h-6V4ZM4 14h6v6H8v-4H4v-2Zm10 0h6v2h-4v4h-2v-6Z"
          ></path>
        </svg>
      </button>
    </div>
  </footer>

  <ContactDialog />

  <script>
    import { initializeConsoleAudio } from "../scripts/console-audio";
    import { getLocale, t } from "../scripts/i18n";

    initializeConsoleAudio();

    const timeElements = document.querySelectorAll<HTMLElement>(
      "[data-console-time]",
    );
    const dateElements = document.querySelectorAll<HTMLElement>(
      "[data-console-date]",
    );
    const themeToggle = document.querySelector<HTMLButtonElement>(
      "[data-theme-toggle]",
    );
    const themeLabel =
      document.querySelector<HTMLElement>("[data-theme-label]");
    const fullscreenToggle = document.querySelector<HTMLButtonElement>(
      "[data-fullscreen-toggle]",
    );
    const musicChannelOpen = document.querySelector<HTMLButtonElement>(
      "[data-music-channel-open]",
    );
    const consoleBackButton = document.querySelector<HTMLButtonElement>(
      "[data-console-back]",
    );
    const galleryPanel = document.querySelector<HTMLElement>(
      '[data-console-view-panel="gallery"]',
    );
    const aboutPanel = document.querySelector<HTMLElement>(
      '[data-console-view-panel="about"]',
    );
    const aboutHeading = document.querySelector<HTMLElement>(
      "[data-about-heading]",
    );
    const musicPanel = document.querySelector<HTMLElement>(
      '[data-console-view-panel="music"]',
    );
    const musicHeading = document.querySelector<HTMLElement>(
      "[data-music-heading]",
    );
    let viewFocusTimer: number | null = null;

    type ConsoleView = "gallery" | "about" | "music";
    type HistoryMode = "none" | "push" | "replace";

    const applyConsoleView = (
      view: ConsoleView,
      historyMode: HistoryMode = "none",
      focusTarget = false,
    ) => {
      const baseUrl = `${window.location.pathname}${window.location.search}`;
      const viewUrl = `${baseUrl}#${view}`;

      if (historyMode === "push") {
        window.history.pushState({ consoleView: view }, "", viewUrl);
      } else if (historyMode === "replace") {
        window.history.replaceState({ consoleView: view }, "", viewUrl);
      }

      document.documentElement.dataset.consoleView = view;
      const galleryIsActive = view === "gallery";
      const aboutIsActive = view === "about";
      const musicIsActive = view === "music";
      galleryPanel?.setAttribute("aria-hidden", String(!galleryIsActive));
      galleryPanel?.toggleAttribute("inert", !galleryIsActive);
      aboutPanel?.setAttribute("aria-hidden", String(!aboutIsActive));
      aboutPanel?.toggleAttribute("inert", !aboutIsActive);
      musicPanel?.setAttribute("aria-hidden", String(!musicIsActive));
      musicPanel?.toggleAttribute("inert", !musicIsActive);
      musicChannelOpen?.setAttribute("aria-pressed", String(musicIsActive));

      if (consoleBackButton) {
        consoleBackButton.setAttribute("aria-hidden", String(galleryIsActive));
        consoleBackButton.tabIndex = galleryIsActive ? -1 : 0;
      }

      window.dispatchEvent(
        new CustomEvent("console:view-changed", { detail: { view } }),
      );

      if (viewFocusTimer !== null) window.clearTimeout(viewFocusTimer);
      if (focusTarget) {
        const requestedWithGamepad =
          document.documentElement.dataset.inputMode === "gamepad";
        const reducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;
        viewFocusTimer = window.setTimeout(
          () => {
            if (
              requestedWithGamepad &&
              document.documentElement.dataset.inputMode !== "gamepad"
            ) {
              return;
            }
            const target = galleryIsActive
              ? null
              : aboutIsActive
                ? aboutHeading
                : (musicPanel?.querySelector<HTMLButtonElement>(
                    '[data-music-disc][data-carousel-position="active"]',
                  ) ?? musicHeading);
            target?.focus({ preventScroll: true });
          },
          reducedMotion ? 0 : 440,
        );
      }
    };

    window.addEventListener("console:view-request", (event) => {
      const request = (
        event as CustomEvent<{
          view?: ConsoleView;
          historyMode?: HistoryMode;
        }>
      ).detail;
      const requestedView = request?.view;
      if (
        requestedView !== "gallery" &&
        requestedView !== "about" &&
        requestedView !== "music"
      )
        return;
      if (document.documentElement.dataset.consoleView === requestedView)
        return;
      applyConsoleView(requestedView, request?.historyMode ?? "push", true);
    });

    musicChannelOpen?.addEventListener("click", (event) => {
      const focusViewTarget =
        document.documentElement.dataset.inputMode !== "gamepad" &&
        event.detail === 0;
      if (document.documentElement.dataset.consoleView === "music") {
        applyConsoleView("gallery", "push", focusViewTarget);
        return;
      }
      applyConsoleView("music", "push", focusViewTarget);
    });

    consoleBackButton?.addEventListener("click", () => {
      if (
        (window.location.hash === "#about" ||
          window.location.hash === "#music") &&
        window.history.state?.consoleView
      ) {
        window.history.back();
        return;
      }
      applyConsoleView("gallery", "replace", true);
    });

    window.addEventListener("popstate", () => {
      const view =
        window.location.hash === "#about"
          ? "about"
          : window.location.hash === "#music"
            ? "music"
            : "gallery";
      applyConsoleView(view, "none", true);
    });

    const updateConsoleTime = () => {
      const now = new Date();
      const locale = getLocale();
      const time = new Intl.DateTimeFormat(locale, {
        timeZone: "Europe/Berlin",
        hour: "2-digit",
        minute: "2-digit",
        hour12: false,
      }).format(now);
      const date = new Intl.DateTimeFormat(locale, {
        timeZone: "Europe/Berlin",
        day: "numeric",
        month: "long",
        year: "numeric",
      }).format(now);

      timeElements.forEach((element) => (element.textContent = time));
      dateElements.forEach((element) => (element.textContent = date));
    };

    const updateThemeLabel = () => {
      const theme = document.documentElement.dataset.consoleTheme;
      if (themeLabel) {
        themeLabel.textContent =
          theme === "dark" ? t("controls.lightMode") : t("controls.darkMode");
      }
    };

    themeToggle?.addEventListener("click", () => {
      const current = document.documentElement.dataset.consoleTheme;
      const next = current === "dark" ? "light" : "dark";
      document.documentElement.dataset.consoleTheme = next;
      try {
        localStorage.setItem("dh-console-theme", next);
      } catch {
        // Theme persistence is optional.
      }
      updateThemeLabel();
      window.dispatchEvent(
        new CustomEvent("console:theme-changed", {
          detail: { theme: next },
        }),
      );
    });

    const updateFullscreenControl = () => {
      if (!fullscreenToggle) return;
      const isFullscreen = Boolean(document.fullscreenElement);
      fullscreenToggle.setAttribute("aria-pressed", String(isFullscreen));
      fullscreenToggle.setAttribute(
        "aria-label",
        isFullscreen
          ? t("controls.exitFullscreen")
          : t("controls.enterFullscreen"),
      );
      fullscreenToggle.title = isFullscreen
        ? t("controls.exitFullscreen")
        : t("controls.enterFullscreen");
    };

    if (fullscreenToggle && !document.fullscreenEnabled) {
      fullscreenToggle.hidden = true;
    } else {
      fullscreenToggle?.addEventListener("click", async () => {
        try {
          if (document.fullscreenElement) {
            await document.exitFullscreen();
          } else {
            await document.documentElement.requestFullscreen();
          }
        } catch {
          // Some browsers can reject fullscreen outside an active user gesture.
        }
      });
      document.addEventListener("fullscreenchange", updateFullscreenControl);
      updateFullscreenControl();
    }

    const systemTheme = window.matchMedia("(prefers-color-scheme: dark)");
    systemTheme.addEventListener("change", (event) => {
      let storedTheme = null;
      try {
        storedTheme = localStorage.getItem("dh-console-theme");
      } catch {
        storedTheme = null;
      }
      if (!storedTheme) {
        const nextTheme = event.matches ? "dark" : "light";
        document.documentElement.dataset.consoleTheme = nextTheme;
        updateThemeLabel();
        window.dispatchEvent(
          new CustomEvent("console:theme-changed", {
            detail: { theme: nextTheme },
          }),
        );
      }
    });

    updateConsoleTime();
    updateThemeLabel();
    window.addEventListener("console:language-changed", () => {
      updateConsoleTime();
      updateThemeLabel();
      updateFullscreenControl();
    });
    applyConsoleView(
      window.location.hash === "#about"
        ? "about"
        : window.location.hash === "#music"
          ? "music"
          : "gallery",
    );
    window.setInterval(updateConsoleTime, 60_000);
  </script>
</BaseLayout>
