---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectHub from "../components/ProjectHub.astro";
import SiteFooter from "../components/SiteFooter.astro";
import StartupScreen from "../components/StartupScreen.astro";
import { projects } from "../data/projects";
import "../styles/console.css";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://www.dhenschel.de/#person",
      name: "D. Henschel",
      url: "https://www.dhenschel.de",
      sameAs: ["https://github.com/dhenschel"],
      jobTitle: "Software Developer",
    },
    {
      "@type": "CollectionPage",
      name: "D. Henschel — Website Console",
      url: "https://www.dhenschel.de/",
      about: { "@id": "https://www.dhenschel.de/#person" },
      mainEntity: {
        "@type": "ItemList",
        itemListElement: projects
          .filter((project) => project.url)
          .map((project, index) => ({
            "@type": "ListItem",
            position: index + 1,
            item: {
              "@type": "WebSite",
              name: project.title,
              url: project.url,
              creator: { "@id": "https://www.dhenschel.de/#person" },
            },
          })),
      },
    },
  ],
};
---

<BaseLayout
  title="D. Henschel — Website Console"
  description="Die persönliche Website-Konsole von D. Henschel mit ClipCollection, CozySite, Restaurant Lava und kommenden Projekten."
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(structuredData)}
  />

  <StartupScreen />

  <main id="main-content" class="console-home">
    <section class="console-stage" aria-label="Website-Konsole">
      <header class="console-bar">
        <a class="console-brand" href="/" aria-label="D. Henschel – Home">
          <span>DH</span>
          <strong>HOME</strong>
        </a>

        <div class="console-player">
          <div class="player-avatar player-avatar--small" aria-hidden="true">
            DH
          </div>
          <span><small>Player 01</small><strong>D. Henschel</strong></span>
        </div>

        <nav class="console-nav" aria-label="Schnellzugriff">
          <a href="#profil">Profil</a>
          <a
            href="https://github.com/dhenschel"
            target="_blank"
            rel="noreferrer"
          >
            GitHub ↗
          </a>
          <button type="button" data-replay-startup>Intro abspielen</button>
        </nav>

        <div class="console-time">
          <time data-console-time>--:--</time>
          <span data-console-date>--.--.----</span>
        </div>
      </header>

      <div class="console-stage__intro">
        <span class="console-stage__online"><i></i> System online</span>
        <p>
          Das ist meine kleine Website-Konsole. Jeder Kanal ist ein Projekt –
          auswählen, ansehen und direkt starten.
        </p>
      </div>

      <ProjectHub />
    </section>

    <section class="player-profile" id="profil" aria-labelledby="profile-title">
      <div class="player-profile__inner">
        <div class="player-profile__aside">
          <p>Player card / 01</p>
          <div class="player-avatar player-avatar--profile" aria-hidden="true">
            <span>DH</span>
            <small>Portrait folgt</small>
          </div>
          <button type="button" data-replay-startup>Startup ansehen</button>
        </div>

        <div class="player-profile__copy">
          <p class="player-profile__kicker">D. Henschel · Software Developer</p>
          <h2 id="profile-title">
            Meine Projekte bekommen ein gemeinsames Zuhause.
          </h2>
          <p>
            Diese Konsole sammelt Websites, Experimente und kleine Produkte, die
            ich entwickle. Manche sind praktisch, manche bewusst verspielt – und
            mit jedem neuen Projekt kommt ein weiterer Titel in die Bibliothek.
          </p>
          <div class="player-profile__links">
            <a href="#weitere-titel">Was als Nächstes kommt ↓</a>
            <a
              href="https://github.com/dhenschel"
              target="_blank"
              rel="noreferrer"
            >
              GitHub-Profil ↗
            </a>
          </div>
        </div>

        <dl class="player-stats">
          <div>
            <dt>Veröffentlicht</dt><dd>03</dd><span>Websites online</span>
          </div>
          <div><dt>Bibliothek</dt><dd>∞</dd><span>bereit für mehr</span></div>
          <div>
            <dt>Aktueller Modus</dt><dd>BUILD</dd><span>Portfolio wächst</span>
          </div>
        </dl>
      </div>
    </section>

    <section
      class="release-queue"
      id="weitere-titel"
      aria-labelledby="queue-title"
    >
      <div class="release-queue__inner">
        <header>
          <p>Download queue</p>
          <h2 id="queue-title">Als Nächstes</h2>
          <span>Die Konsole ist vorbereitet – die Inhalte wachsen mit.</span>
        </header>

        <ol class="release-list">
          <li>
            <span class="release-list__state">01</span>
            <div>
              <strong>Persönliches Portrait</strong><p>
                Das ausgewählte Foto ersetzt später den DH-Platzhalter im Player
                Login.
              </p>
            </div>
            <small>ASSET FEHLT</small>
          </li>
          <li>
            <span class="release-list__state">02</span>
            <div>
              <strong>Weitere Websites</strong><p>
                Jedes neue Projekt erhält Cover, Farbe, Beschreibung und einen
                eigenen Start-Button.
              </p>
            </div>
            <small>READY</small>
          </li>
          <li>
            <span class="release-list__state">03</span>
            <div>
              <strong>Startup verfeinern</strong><p>
                Animation, Timing und Sound können später mit deiner
                persönlichen Bildwelt erweitert werden.
              </p>
            </div>
            <small>PROTOTYPE</small>
          </li>
        </ol>
      </div>
    </section>
  </main>

  <SiteFooter />

  <script>
    const timeElements = document.querySelectorAll<HTMLElement>(
      "[data-console-time]",
    );
    const dateElements = document.querySelectorAll<HTMLElement>(
      "[data-console-date]",
    );

    const updateConsoleTime = () => {
      const now = new Date();
      const time = new Intl.DateTimeFormat("de-DE", {
        timeZone: "Europe/Berlin",
        hour: "2-digit",
        minute: "2-digit",
        hour12: false,
      }).format(now);
      const date = new Intl.DateTimeFormat("de-DE", {
        timeZone: "Europe/Berlin",
        day: "2-digit",
        month: "2-digit",
        year: "numeric",
      }).format(now);

      timeElements.forEach((element) => (element.textContent = time));
      dateElements.forEach((element) => (element.textContent = date));
    };

    updateConsoleTime();
    window.setInterval(updateConsoleTime, 60_000);
  </script>
</BaseLayout>
