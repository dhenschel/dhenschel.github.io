---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout
  title="Datenschutz — D. Henschel"
  titleKey="page.privacy.title"
  noindex
>
  <SiteHeader compact />
  <main id="main-content" class="legal-page shell">
    <p class="eyebrow">LEGAL / 02</p>
    <h1 data-i18n="common.privacy">Datenschutz</h1>
    <div class="legal-notice">
      <strong data-i18n="legal.placeholderTitle"
        >Vor dem offiziellen Launch zu vervollständigen</strong
      >
      <p data-i18n="legal.privacy.placeholder">
        Die Website setzt derzeit selbst keine Cookies, kein Analytics und keine
        extern geladenen Schriften ein. Die vollständigen Hinweise müssen noch
        auf Hosting, Betreiberangaben und die finale Drittanbieterkonfiguration
        abgestimmt werden.
      </p>
    </div>
    <p data-i18n="legal.privacy.note">
      Dieser technische Hinweis ersetzt keine individuell passende
      Datenschutzerklärung. Die Seite ist bis zur Fertigstellung von der
      Indexierung ausgeschlossen.
    </p>
    <a class="text-link" href="/" data-i18n="legal.backHome">← Zur Startseite</a
    >
  </main>
  <SiteFooter />
</BaseLayout>
