---
import "../styles/global.css";
import { siteMetadata, siteProfile } from "../data/site";

type OpenGraphType = "website" | "article" | "profile";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  imageType?: string;
  imageWidth?: number;
  imageHeight?: number;
  canonicalPath?: string;
  openGraphType?: OpenGraphType;
  noindex?: boolean;
  structuredData?: Record<string, unknown>;
  titleKey?: string;
  descriptionKey?: string;
  bodyClass?: string;
}

const {
  title = siteMetadata.defaultTitle,
  description = siteMetadata.defaultDescription,
  image = siteMetadata.socialImage,
  imageAlt = siteMetadata.socialImageAlt,
  imageType = "image/png",
  imageWidth = siteMetadata.socialImageWidth,
  imageHeight = siteMetadata.socialImageHeight,
  canonicalPath = Astro.url.pathname,
  openGraphType = "website",
  noindex = false,
  structuredData,
  titleKey,
  descriptionKey,
  bodyClass,
} = Astro.props;

const baseUrl = Astro.site ?? new URL(siteMetadata.url);
const canonicalUrl = new URL(canonicalPath, baseUrl);
const socialImageUrl = new URL(image, baseUrl);
const robots = noindex
  ? "noindex, follow"
  : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
const serializedStructuredData = structuredData
  ? JSON.stringify(structuredData).replace(/</g, "\\u003c")
  : undefined;
---

<!doctype html>
<html lang={siteMetadata.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (() => {
        const supported = ["de", "en", "fr", "es"];
        let stored = null;
        try {
          stored = localStorage.getItem("dh-console-language");
        } catch {
          stored = null;
        }
        const browserLanguage = navigator.language.slice(0, 2).toLowerCase();
        const language = supported.includes(stored)
          ? stored
          : supported.includes(browserLanguage)
            ? browserLanguage
            : "de";
        document.documentElement.lang = language;
        document.documentElement.dataset.language = language;
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteProfile.fullName} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content={siteMetadata.themeColor} />
    <meta name="color-scheme" content="dark light" />
    <meta name="generator" content={Astro.generator} />
    {!noindex && <link rel="canonical" href={canonicalUrl.href} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content={openGraphType} />
    <meta property="og:locale" content={siteMetadata.locale} />
    <meta property="og:site_name" content={siteMetadata.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={socialImageUrl.href} />
    <meta property="og:image:secure_url" content={socialImageUrl.href} />
    <meta property="og:image:type" content={imageType} />
    <meta property="og:image:width" content={String(imageWidth)} />
    <meta property="og:image:height" content={String(imageHeight)} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl.href} />
    <meta name="twitter:image:alt" content={imageAlt} />

    {
      serializedStructuredData && (
        <script
          is:inline
          type="application/ld+json"
          set:html={serializedStructuredData}
        />
      )
    }
  </head>
  <body
    class={bodyClass}
    data-i18n-document-title={titleKey}
    data-i18n-document-description={descriptionKey}
  >
    <script>
      import { initializeConsoleGamepad } from "../scripts/console-gamepad";
      import { initializeI18n } from "../scripts/i18n";

      initializeI18n();
      initializeConsoleGamepad();
    </script>
    <a class="skip-link" href="#main-content" data-i18n="common.skipContent"
      >Zum Inhalt springen</a
    >
    <aside
      class="portrait-orientation-guard"
      role="dialog"
      aria-modal="true"
      aria-labelledby="portrait-guard-title"
    >
      <div class="portrait-orientation-guard__device" aria-hidden="true">
        <span></span>
      </div>
      <p data-i18n="orientation.eyebrow">Querformat erforderlich</p>
      <h1 id="portrait-guard-title" data-i18n="orientation.title">
        Bitte drehe dein Gerät
      </h1>
      <p data-i18n="orientation.description">
        Diese Konsole ist für das Querformat gestaltet.
      </p>
      <div class="desktop-experience-hint">
        <span class="desktop-experience-hint__icon" aria-hidden="true"></span>
        <span data-i18n="orientation.desktopHint"
          >Beste Erfahrung auf Desktop</span
        >
      </div>
    </aside>
    <div class="mobile-desktop-hint" role="status">
      <span class="desktop-experience-hint__icon" aria-hidden="true"></span>
      <span data-i18n="orientation.desktopHint"
        >Beste Erfahrung auf Desktop</span
      >
    </div>
    <slot />
  </body>
</html>
