---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  titleKey?: string;
  descriptionKey?: string;
}

const {
  title = "D. Henschel — Software Developer",
  description = "Portfolio von D. Henschel: digitale Produkte mit System und Charakter.",
  image = "/social-card.svg",
  noindex = false,
  titleKey,
  descriptionKey,
} = Astro.props;

const baseUrl = Astro.site ?? Astro.url.origin;
const canonicalUrl = new URL(Astro.url.pathname, baseUrl);
const socialImageUrl = new URL(image, baseUrl);
---

<!doctype html>
<html lang="de">
  <head>
    <script is:inline>
      (() => {
        const supported = ["de", "en", "fr", "es"];
        let stored = null;
        try {
          stored = localStorage.getItem("dh-console-language");
        } catch {
          stored = null;
        }
        const browserLanguage = navigator.language.slice(0, 2).toLowerCase();
        const language = supported.includes(stored)
          ? stored
          : supported.includes(browserLanguage)
            ? browserLanguage
            : "de";
        document.documentElement.lang = language;
        document.documentElement.dataset.language = language;
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0b0d10" />
    <meta name="color-scheme" content="dark" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />

    <title>{title}</title>
  </head>
  <body
    data-i18n-document-title={titleKey}
    data-i18n-document-description={descriptionKey}
  >
    <script>
      import { initializeI18n } from "../scripts/i18n";

      initializeI18n();
    </script>
    <a class="skip-link" href="#main-content" data-i18n="common.skipContent"
      >Zum Inhalt springen</a
    >
    <slot />
  </body>
</html>
